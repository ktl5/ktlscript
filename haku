local scriptsToLoad = {
    "https://raw.githubusercontent.com/ktl5/ktlscript/refs/heads/main/ktlhub",
    "https://raw.githubusercontent.com/ktl5/ktlscript/refs/heads/main/test",
}

for i, url in ipairs(scriptsToLoad) do
    task.spawn(function()
        -- pcall permet d'attraper les erreurs sans faire crasher l'exécuteur
        local success, err = pcall(function()
            loadstring(game:HttpGet(url))()
        end)
        
        if not success then
            warn("Erreur lors du chargement du script " .. i .. " : " .. tostring(err))
        end
    end)
    
    -- Pause de 0.5 seconde entre chaque exécution pour éviter les lags
    task.wait(0.5)
end

print("Tous les scripts ont été lancés avec succès !")
