(function initVis() {
  const canvas = document.getElementById('vis-canvas');
  const ctx = canvas.getContext('2d');
  const BAR_COUNT = 52;
  let phases = Array.from({length: BAR_COUNT}, () => Math.random() * Math.PI * 2);
  let speeds = Array.from({length: BAR_COUNT}, () => .025 + Math.random() * .035);

  function resize() {
    canvas.width  = canvas.offsetWidth  * devicePixelRatio;
    canvas.height = canvas.offsetHeight * devicePixelRatio;
    ctx.scale(devicePixelRatio, devicePixelRatio);
  }
  resize();
  window.addEventListener('resize', resize);

  function draw() {
    const w = canvas.offsetWidth, h = canvas.offsetHeight;
    ctx.clearRect(0, 0, w, h);
    const bw = Math.max(1, (w - (BAR_COUNT - 1) * 2) / BAR_COUNT);
    const freqs = AudioState.getFreqs();

    phases.forEach((ph, i) => {
      phases[i] += speeds[i] * (VisState.playing ? 1 : 0.3);
      let amp;
      if (freqs) {
        const bin = Math.floor(i / BAR_COUNT * freqs.length * 0.7);
        const raw = freqs[bin] / 255;
        amp = raw * 0.85 + (Math.sin(phases[i]) * 0.5 + 0.5) * 0.15;
      } else {
        const energy = VisState.playing ? 1 : 0.25;
        const wave1 = Math.sin(phases[i]) * .5 + .5;
        const wave2 = Math.sin(phases[i] * .7 + i * .15) * .5 + .5;
        const bass  = i < 10 ? 1 + Math.sin(phases[0] * .5) * .5 * energy : 1;
        amp = (wave1 * .6 + wave2 * .4) * bass * energy;
      }
      const bh    = 3 + amp * (h - 6);
      const x     = i * (bw + 2);
      const y     = (h - bh) / 2;
      ctx.fillStyle = `rgba(180,160,255,${.2 + amp * .7})`;
      ctx.beginPath();
      ctx.roundRect(x, y, bw, bh, 2);
      ctx.fill();
    });
    requestAnimationFrame(draw);
  }
  draw();
})();

