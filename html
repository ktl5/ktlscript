═══════════════════════════════════════════════ */

// ── BACKGROUND CANVAS (Enhanced Aura + Interactive Particles) ──
(function initBg() {
  const canvas = document.getElementById('bg-canvas');
  const ctx = canvas.getContext('2d');
  let t = 0;
  let mouse = { x: -1000, y: -1000 };

  // Enhanced blobs with more dynamic movement and colors
  const blobs = [
    { x: 0.2, y: 0.2, r: 0.7, h: 260, s: 0.5, speed: 0.0004, ampX: 0.2, ampY: 0.15 },
    { x: 0.8, y: 0.8, r: 0.8, h: 285, s: 0.4, speed: 0.0003, ampX: 0.18, ampY: 0.2 },
    { x: 0.5, y: 0.5, r: 0.6, h: 240, s: 0.3, speed: 0.0005, ampX: 0.1, ampY: 0.1 }
  ];

  // Further reduced particles for performance
  const particles = Array.from({ length: 20 }, () => ({
    x: Math.random(),
    y: Math.random(),
    s: 0.5 + Math.random() * 1.0,
    o: 0.1 + Math.random() * 0.3,
    vx: (Math.random() - 0.5) * 0.0006,
    vy: (Math.random() - 0.5) * 0.0006,
    pulse: Math.random() * Math.PI
  }));

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);
  window.addEventListener('mousemove', e => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });

  let lastDrawTime = 0;
  function draw(currentTime) {
    requestAnimationFrame(draw);
    
    // Limit background animation to ~40 FPS for better performance
    if (currentTime - lastDrawTime < 25) return; 
    lastDrawTime = currentTime;

    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // 1. Draw Enhanced Aura Blobs (Screen blending)
    ctx.globalCompositeOperation = 'screen';
    blobs.forEach(b => {
      const bx = (b.x + Math.sin(t * b.speed + b.h) * b.ampX) * canvas.width;
      const by = (b.y + Math.cos(t * b.speed * 0.8 + b.h) * b.ampY) * canvas.height;
      const br = b.r * Math.max(canvas.width, canvas.height);
      
      const g = ctx.createRadialGradient(bx, by, 0, bx, by, br);
      g.addColorStop(0, `hsla(${b.h}, 60%, 70%, 0.12)`);
      g.addColorStop(0.4, `hsla(${b.h}, 50%, 60%, 0.04)`);
      g.addColorStop(1, 'transparent');
      
      ctx.fillStyle = g;
      // Use a circular path for the gradient to avoid filling the whole screen multiple times
      ctx.beginPath();
      ctx.arc(bx, by, br, 0, Math.PI * 2);
      ctx.fill();
    });

    // 2. Draw Interactive Floating Particles
    ctx.globalCompositeOperation = 'source-over';
    ctx.shadowBlur = 0; // Ensure shadow is disabled for batch drawing
    particles.forEach(p => {
      // Natural movement
      p.x += p.vx;
      p.y += p.vy;
      
      // Wrap around screen
      if (p.x < -0.1) p.x = 1.1; if (p.x > 1.1) p.x = -0.1;
      if (p.y < -0.1) p.y = 1.1; if (p.y > 1.1) p.y = -0.1;

      let px = p.x * canvas.width;
      let py = p.y * canvas.height;

      // Mouse interaction (repulsion)
      const dx = mouse.x - px;
      const dy = mouse.y - py;
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < 300) {
        const force = (300 - dist) / 300;
        px -= dx * force * 0.08;
        py -= dy * force * 0.08;
      }

      // Pulse effect
      const currentOpacity = p.o * (0.6 + Math.sin(t * 0.02 + p.pulse) * 0.4);
      
      ctx.fillStyle = `rgba(255, 255, 255, ${currentOpacity})`;
      ctx.beginPath();
      ctx.arc(px, py, p.s, 0, Math.PI * 2);
      ctx.fill();
    });

    t++;
  }
  requestAnimationFrame(draw);
})();

// ── WEB AUDIO API SETUP ────────────────────────
const AudioState = {
  ctx: null, analyser: null, source: null, data: null, ready: false,
  init() {
    if (this.ctx) {
      if (this.ctx.state === 'suspended') this.ctx.resume();
      return;
    }
    try {
      const audio = document.getElementById('aud');
      this.ctx = new (window.AudioContext || window.webkitAudioContext)();
      this.source = this.ctx.createMediaElementSource(audio);
      this.analyser = this.ctx.createAnalyser();
      this.analyser.fftSize = 256;
      this.analyser.smoothingTimeConstant = 0.82;
      this.source.connect(this.analyser);
      this.analyser.connect(this.ctx.destination);
      this.data = new Uint8Array(this.analyser.frequencyBinCount);
      this.ready = true;
      this.ctx.resume();
    } catch(e) {
      console.warn('Web Audio API unavailable, using fallback animation:', e.message);
      this.ready = false;
    }
  },
  getFreqs() {
    if (!this.ready || !this.analyser) return null;
    try {
      this.analyser.getByteFrequencyData(this.data);
      return this.data;
    } catch(e) { return null; }
  }
};

