      title: "Kerchak x Pink Lemonade",
      artist: "Kerchak",
      cover: "https://i.imgur.com/dijpYCz.png"
    },
    {
      src: "https://files.catbox.moe/q8feoi.mp3",
      title: "WAGNER GROUP",
      artist: "FREEZE CORLEONE",
      cover: "https://i.imgur.com/jyHIZRA.jpeg"
    }
  ];

  let currentTrack = 0;
  
  // Preload all covers immediately (lightweight, doesn't affect load time)
  const preloadedCovers = [];
  playlist.forEach(track => {
    const img = new Image();
    img.src = track.cover;
    preloadedCovers.push(img);
  });

  function loadTrack(index, shouldPlay = false) {
     const track = playlist[index];
     console.log("Loading track:", index, track);
     
     // Update UI first (instant feedback)
     trackName.textContent = track.title;
     spTitle.textContent = track.title;
     spArtist.textContent = track.artist;
     spArt.style.backgroundImage = `url('${track.cover}')`;
     
     // Set audio source
     console.log("Current audio src:", audio.src);
     console.log("New track src:", track.src);
     if (audio.src !== track.src) {
       audio.src = track.src;
       audio.preload = 'auto';
       console.log("Updated audio src to:", audio.src);
     }

     if (shouldPlay) {
       const playPromise = audio.play();
       if (playPromise !== undefined) {
         playPromise.then(() => {
           setPlaying(true);
           // Preload next track after current starts playing
           preloadNext();
         }).catch(err => {
           console.error('Playback failed:', err);
           setPlaying(false);
         });
       }
     } else {
       // Just preload if not playing
       preloadNext();
     }
   }

   function nextTrack() {
     currentTrack = (currentTrack + 1) % playlist.length;
     loadTrack(currentTrack, true);
   }

   function prevTrack() {
     currentTrack = (currentTrack - 1 + playlist.length) % playlist.length;
     loadTrack(currentTrack, true);
   }
   
   function preloadNext() {
     const nextIdx = (currentTrack + 1) % playlist.length;
     const link = document.createElement('link');
     link.rel = 'preload';
     link.as = 'audio';
     link.href = playlist[nextIdx].src;
     const oldLinks = document.querySelectorAll('link[rel="preload"][as="audio"]');
     oldLinks.forEach(l => l.remove());
     document.head.appendChild(link);
   }

  function fmt(s) {
    if (isNaN(s)) return '0:00';
    s = Math.floor(s);
    return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
  }

  // Audio event listeners
  audio.addEventListener('loadstart', () => console.log('Audio loadstart'));
  audio.addEventListener('progress', () => console.log('Audio progress'));
  audio.addEventListener('canplay', () => console.log('Audio canplay'));
  audio.addEventListener('canplaythrough', () => console.log('Audio canplaythrough'));
  audio.addEventListener('error', (e) => console.error('Audio error:', e, audio.error));
  
  // Metadata loaded → show real duration
  audio.addEventListener('loadedmetadata', () => {
    console.log('Audio loadedmetadata, duration:', audio.duration);
    ptDur.textContent = fmt(audio.duration);
    document.getElementById('sp-dur').textContent = fmt(audio.duration);
  });

  // Time update → progress bar + timestamps
  audio.addEventListener('timeupdate', () => {
    const pct = audio.duration ? (audio.currentTime / audio.duration * 100) : 0;
    prf.style.width = pct + '%';
    document.getElementById('sp-prog-fill').style.width = pct + '%';
    ptCur.textContent = fmt(audio.currentTime);
    document.getElementById('sp-cur').textContent = fmt(audio.currentTime);
  });

  // Play / Pause toggle — initialises AudioContext on first click (browser policy)
  function setPlaying(isPlaying) {
    VisState.playing = isPlaying;
    plyPause.style.display = isPlaying ? '' : 'none';
    plyPlay.style.display  = isPlaying ? 'none' : '';
  }

  function togglePlay() {
    AudioState.init();
    if (audio.paused) {
      audio.play()
        .then(() => setPlaying(true))
        .catch(err => {
          console.error('Playback failed:', err);
          setPlaying(false);
        });
    } else {
      audio.pause();
      setPlaying(false);
    }
  }

  // Sync UI if audio ends or is paused externally
  audio.addEventListener('ended', nextTrack);
  audio.addEventListener('pause',  () => setPlaying(false));
  audio.addEventListener('playing',() => setPlaying(true));

  plyBtn.addEventListener('click', togglePlay);

  // Seek by clicking progress bar
  document.getElementById('prb').addEventListener('click', e => {
    if (!audio.duration) return;
    const r = e.currentTarget.getBoundingClientRect();
    audio.currentTime = (e.clientX - r.left) / r.width * audio.duration;
  });

  // Previous / Next (Playlist navigation)
  document.getElementById('prv').addEventListener('click', prevTrack);
  document.getElementById('nxt').addEventListener('click', nextTrack);

  // Volume control
  const volSlider = document.getElementById('vol-slider');
  const volBtn = document.getElementById('vlb');
  const volIcons = {
    0: document.getElementById('vol-icon-0'),
    1: document.getElementById('vol-icon-1'),
    2: document.getElementById('vol-icon-2'),
    3: document.getElementById('vol-icon-3')
  };
  let lastVolume = 0.5;
  audio.volume = 0.5;

  function updateVolumeIcon(volume, muted) {
    for (let i = 0; i < 4; i++) {
      volIcons[i].style.display = 'none';
    }
    if (muted || volume === 0) {
      volIcons[0].style.display = 'block';
    } else if (volume < 0.33) {
      volIcons[1].style.display = 'block';
    } else if (volume < 0.66) {
      volIcons[2].style.display = 'block';
    } else {
      volIcons[3].style.display = 'block';
    }
    volBtn.style.opacity = muted ? '.35' : '1';
  }

  volSlider.addEventListener('input', (e) => {
    const vol = e.target.value / 100;
    audio.volume = vol;
    audio.muted = false;
    lastVolume = vol;
    updateVolumeIcon(vol, false);
  });

  volBtn.addEventListener('click', () => {
    if (audio.muted || audio.volume === 0) {
      audio.muted = false;
      audio.volume = lastVolume || 0.5;
      volSlider.value = audio.volume * 100;
      updateVolumeIcon(audio.volume, false);
    } else {
      lastVolume = audio.volume;
      audio.muted = true;
      updateVolumeIcon(audio.volume, true);
    }
  });

  updateVolumeIcon(audio.volume, audio.muted);

  // ── AUTOPLAY LOGIC ──
  const landing = document.getElementById('landing-overlay');
  
  const startAudio = () => {
    AudioState.init();
    audio.muted = false;
    audio.currentTime = 0;
    audio.play()
      .then(() => {
        setPlaying(true);
        if (landing) landing.classList.add('hide');
      })
      .catch(err => {
        console.warn("Playback failed even after click:", err);
      });
  };

  if (landing) {
    landing.addEventListener('click', startAudio);
  }

  // Initial UI state
  loadTrack(0);
  preloadNext();
  plyPause.style.display = 'none';
  plyPlay.style.display  = '';
})();

