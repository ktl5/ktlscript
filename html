(function initCursorTrail() {
  const COLORS = ['rgba(180,160,255,.7)', 'rgba(100,80,220,.7)', 'rgba(220,210,255,.7)', 'rgba(255,255,255,.5)'];
  const MAX = 12;
  const dots = [];
  let mouse = { x: window.innerWidth / 2, y: window.innerHeight / 2 };

  for (let i = 0; i < MAX; i++) {
    const d = document.createElement('div');
    d.className = 'cur-dot';
    const size = (1 - i / MAX) * 6 + 1;
    // Optimization: Add will-change and force GPU layers
    d.style.cssText = `width:${size}px;height:${size}px;opacity:0;background:${COLORS[i % COLORS.length]};box-shadow:0 0 ${size*2}px ${COLORS[i % COLORS.length]};backface-visibility:hidden;will-change:transform,opacity`;
    document.body.appendChild(d);
    dots.push({ el: d, x: mouse.x, y: mouse.y });
  }

  document.addEventListener('mousemove', e => { 
    mouse.x = e.clientX; 
    mouse.y = e.clientY; 
  }, { passive: true });

  (function animate() {
    let lx = mouse.x, ly = mouse.y;
    
    dots.forEach((dot, i) => {
      // Use higher interpolation factor for ultra-smoothness
      dot.x += (lx - dot.x) * 0.35;
      dot.y += (ly - dot.y) * 0.35;
      
      lx = dot.x; 
      ly = dot.y;
      
      const age = i / MAX;
      // Using translate3d is critical for GPU acceleration
      dot.el.style.transform = `translate3d(${dot.x}px,${dot.y}px,0) translate(-50%,-50%)`;
      dot.el.style.opacity = (1 - age) * 0.8;
    });
    
    requestAnimationFrame(animate);
  })();
})();

