  const trackName = document.getElementById('tn');
  const spArt     = document.getElementById('sp-art');
  const spTitle   = document.getElementById('sp-title');
  const spArtist  = document.getElementById('sp-artist');

  const playlist = [
    {
      src: "https://files.catbox.moe/kw6ps6.mp3",
      title: "CAUCHEMARE",
      artist: "zny",
      cover: "https://i.imgur.com/2GGAL4F.jpeg"
    },
    {
      src: "https://files.catbox.moe/a1vpyv.mp3",
