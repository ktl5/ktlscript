(function initPlayerVis() {
  const canvas = document.getElementById('pvis-canvas');
  const ctx = canvas.getContext('2d');
  const BAR_COUNT = 90;
  let phases = Array.from({length: BAR_COUNT}, (_, i) => i * .3);

  function resize() { canvas.width = window.innerWidth; canvas.height = 72; }
  resize();
  window.addEventListener('resize', resize);

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    const bw = canvas.width / BAR_COUNT;
    const freqs = AudioState.getFreqs();

    phases.forEach((ph, i) => {
      phases[i] += (.018 + i * .00015) * (VisState.playing ? 1 : 0.25);
      let amp;
      if (freqs) {
        const bin = Math.floor(i / BAR_COUNT * freqs.length * 0.75);
        amp = freqs[bin] / 255;
        amp = amp * 0.9 + (Math.sin(phases[i]) * 0.5 + 0.5) * 0.1;
      } else {
        const energy = VisState.playing ? 1 : 0.2;
        amp = ((Math.sin(phases[i]) * .5 + .5) * (Math.cos(phases[i] * .3) * .5 + .5)) * energy;
      }
      const bh = 2 + amp * 62;
      ctx.fillStyle = `rgba(180,160,255,${.06 + amp * .28})`;
      ctx.fillRect(i * bw, 72 - bh, bw - 1, bh);
    });
    requestAnimationFrame(draw);
  }
  draw();
})();

