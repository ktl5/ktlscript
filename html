// ── CLOCK & AGE ────────────────────────────────
(function initClock() {
  const BIRTHDAY = new Date('2011-06-28T00:00:00');
  const timeEl = document.getElementById('side-time');
  const ageEl = document.getElementById('side-age');

  function pad(n) { return String(n).padStart(2, '0'); }

  function calcAge(now) {
    let years = now.getFullYear() - BIRTHDAY.getFullYear();
    let m = now.getMonth() - BIRTHDAY.getMonth();
    let d = now.getDate() - BIRTHDAY.getDate();
    if (d < 0) { m--; d += new Date(now.getFullYear(), now.getMonth(), 0).getDate(); }
    if (m < 0) { years--; m += 12; }
    const lastBday = new Date(now.getFullYear(), BIRTHDAY.getMonth(), BIRTHDAY.getDate());
    if (lastBday > now) lastBday.setFullYear(lastBday.getFullYear() - 1);
    const days = Math.floor((now - lastBday) / 864e5);
    return `${years}y ${days}d ${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}`;
  }

  function tick() {
    const now = new Date();
    // Show time in GMT+2 (Berlin/Paris)
    const berlin = new Intl.DateTimeFormat('de-DE', {
      timeZone: 'Europe/Berlin', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false
    });
    timeEl.textContent = berlin.format(now);
    ageEl.textContent = calcAge(now);
  }
  tick();
  setInterval(tick, 1000);
})();

// ── MOON PHASE ─────────────────────────────────
(function initMoon() {
  // Synodic cycle reference: known new moon Jan 6, 2000 UTC
  const REF = new Date('2000-01-06T18:14:00Z');
  const SYNODIC = 29.53059;
  const now = new Date();
  const elapsed = (now - REF) / 864e5; // days
  const phase = ((elapsed % SYNODIC) + SYNODIC) % SYNODIC; // 0-29.53
  const fraction = phase / SYNODIC;
  // Illumination: cos formula
  const illum = Math.round((1 - Math.cos(fraction * 2 * Math.PI)) / 2 * 100);
  
  // Northern Hemisphere (France) Moon Phase Emoji mapping
  const phases = [
    [0,   1.85, '🌑 New Moon'],
    [1.85, 7.38, '🌒 Waxing Crescent'],
    [7.38, 9.22, '🌓 First Quarter'],
    [9.22, 14.77, '🌔 Waxing Gibbous'],
    [14.77, 16.61, '🌕 Full Moon'],
    [16.61, 22.15, '🌖 Waning Gibbous'],
    [22.15, 24.0, '🌗 Last Quarter'],
    [24.0, 29.53, '🌘 Waning Crescent'],
  ];
  let name = '🌑 New Moon';
  for (const [lo, hi, n] of phases) { if (phase >= lo && phase < hi) { name = n; break; } }
  document.getElementById('moon-phase-name').textContent = name;
  document.getElementById('moon-illum').textContent = `${illum}% illuminée (France)`;
})();

