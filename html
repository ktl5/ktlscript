<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DiamonDice700</title>
<link rel="preconnect" href="https://fonts.googleapis.com/">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=Syne:wght@400;500;600;700;800&family=Montserrat:wght@700;800&display=swap" rel="stylesheet">
<style>
:root{
  --player-h:72px;
  --ff-head:'Syne',sans-serif;
  --ff-body:'Plus Jakarta Sans',sans-serif;
  --ff-accent:'Syne',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-user-select:none;user-select:none;-webkit-user-drag:none}
html,body{overflow:hidden;width:100%;height:100%;position:fixed;background:#000}
body{font-family:var(--ff-body)}

/* ── MAIN ── */
#main{position:fixed;inset:0;bottom:var(--player-h);display:flex;flex-direction:column;align-items:center;justify-content:center;overflow:hidden}
#bg-canvas{position:absolute;inset:0;z-index:0;pointer-events:none}
#content{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:12px;padding:0 20px;width:100%;max-width:460px;overflow:visible}

/* ── PROFILE CARD ── */
.profile-card{width:100%;background:rgba(255,255,255,.035);backdrop-filter:blur(20px) saturate(160%);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:22px 22px 18px;box-shadow:0 8px 48px rgba(0,0,0,.6),0 0 0 1px rgba(255,255,255,.04) inset,0 1px 0 rgba(255,255,255,.08) inset;will-change:transform,opacity;transform:translateZ(0)}
.profile-top{display:flex;align-items:center;gap:18px;margin-bottom:16px}

/* ── AVATAR ── */
.avatar-wrap{position:relative;flex-shrink:0;width:76px;height:76px}
.avatar-aura{position:absolute;inset:-14px;border-radius:50%;background:radial-gradient(circle,rgba(180,160,255,.35) 0%,transparent 70%);filter:blur(20px);animation:aura-pulse 4s ease-in-out infinite;will-change:opacity}
@keyframes aura-pulse{0%,100%{opacity:.3}50%{opacity:.7}}
.avatar-ring{position:absolute;inset:0;border-radius:50%;border:1.5px solid rgba(255,255,255,.25);box-shadow:0 0 28px rgba(180,160,255,.2)}
.avatar-img{width:76px;height:76px;border-radius:50%;object-fit:cover;position:relative;z-index:1;display:block}
/* CSS fallback avatar */
.avatar-fallback{width:76px;height:76px;border-radius:50%;background:linear-gradient(135deg,#6d4fc2 0%,#a78bfa 50%,#c4b5fd 100%);display:flex;align-items:center;justify-content:center;font-family:var(--ff-head);font-size:30px;font-weight:800;color:rgba(255,255,255,.95);position:relative;z-index:1;letter-spacing:-.02em;text-shadow:0 2px 8px rgba(0,0,0,.3)}
/* decorative ring overlay */
.avatar-deco-ring{position:absolute;inset:-6px;border-radius:50%;border:1.5px solid rgba(180,160,255,.4);z-index:10;animation:deco-spin 12s linear infinite}
@keyframes deco-spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
.avatar-deco-dots{position:absolute;inset:-6px;border-radius:50%;z-index:10;animation:deco-spin 12s linear infinite}
.avatar-deco-dots::before,.avatar-deco-dots::after{content:'';position:absolute;width:5px;height:5px;border-radius:50%;background:rgba(180,160,255,.8);box-shadow:0 0 6px rgba(180,160,255,.6)}
.avatar-deco-dots::before{top:2px;left:50%;transform:translateX(-50%)}
.avatar-deco-dots::after{bottom:2px;left:50%;transform:translateX(-50%)}

.status-dot{position:absolute;bottom:-1px;right:-1px;width:20px;height:20px;border-radius:50%;border:3px solid #000;z-index:20;background:#4e5157}
.status-dot.online{background:#23a55a;box-shadow:0 0 0 3px rgba(35,165,90,.2),0 0 10px rgba(35,165,90,.4)}
.status-dot.idle{background:#f0b232;box-shadow:0 0 0 3px rgba(240,178,50,.2),0 0 10px rgba(240,178,50,.4)}
.status-dot.dnd{background:#f23f43;box-shadow:0 0 0 3px rgba(242,63,67,.2),0 0 10px rgba(242,63,67,.4)}
.status-dot.offline{background:#4e5157}

/* ── LANDING OVERLAY ── */
#landing-overlay {
  position: fixed;
  inset: 0;
  z-index: 10000;
  background: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.8s;
}
#landing-overlay.hide {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}
.enter-text {
  font-family: var(--ff-head);
  font-size: 14px;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  animation: pulse-text 2s infinite;
}
@keyframes pulse-text {
  0%, 100% { opacity: 0.4; transform: scale(0.98); }
  50% { opacity: 1; transform: scale(1); }
}

/* ── PROFILE META ── */
.profile-meta{flex:1;min-width:0}
.profile-name{font-family:var(--ff-head);font-size:26px;font-weight:800;color:rgba(255,255,255,.98);letter-spacing:-.03em;display:flex;align-items:center;gap:8px;flex-wrap:wrap;text-shadow:0 0 30px rgba(255,255,255,.25);margin-bottom:6px}
.quote-wrap{min-height:22px;overflow:hidden}
.quote-text{font-family:var(--ff-body);font-size:13px;font-weight:400;font-style:italic;color:rgba(255,255,255,.55);white-space:nowrap;display:inline-block;min-width:1px;letter-spacing:-.01em}
.mobile-br{display:none}
.typing-cursor{display:inline-block;width:1px;height:13px;background:rgba(180,160,255,.7);margin-left:1px;vertical-align:middle;animation:blink .8s step-end infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}

/* ── VISUALIZER ── */
.vis-wrap{width:100%;height:44px;border-radius:8px;overflow:hidden;position:relative;background:rgba(0,0,0,.2);margin-top:4px}
#vis-canvas{width:100%;height:100%}

/* ── ACTIVITIES ── */
.activities{width:100%;display:flex;flex-direction:column;gap:8px}
.act-item{width:100%;background:rgba(255,255,255,.03);backdrop-filter:blur(15px);border:1px solid rgba(255,255,255,.12);border-radius:14px;padding:12px 14px;display:flex;gap:12px;align-items:center;box-shadow:0 4px 20px rgba(0,0,0,.3);transition:border-color .3s,background .3s;will-change:transform,opacity;transform:translateZ(0)}
.act-item:hover{border-color:rgba(255,255,255,.2);background:rgba(255,255,255,.05)}
.act-thumb{width:44px;height:44px;border-radius:8px;object-fit:cover;flex-shrink:0;background:rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;font-size:22px}
.act-info{flex:1;min-width:0}
.act-name{font-family:var(--ff-head);font-size:14px;font-weight:700;color:rgba(255,255,255,.9);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:2px;letter-spacing:-.01em}
.act-detail{font-family:var(--ff-body);font-size:12px;font-weight:450;color:rgba(255,255,255,.6);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.act-state{font-family:var(--ff-body);font-size:11px;font-weight:400;color:rgba(255,255,255,.4);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.act-badge{font-family:var(--ff-head);font-size:9px;font-weight:700;letter-spacing:.1em;color:rgba(180,160,255,.9);background:rgba(180,160,255,.1);border:1px solid rgba(180,160,255,.2);border-radius:20px;padding:2px 7px;flex-shrink:0;text-transform:uppercase}

/* ── SPOTIFY CARD ── */
#sp-card{width:100%;background:rgba(255,255,255,.03);backdrop-filter:blur(15px);border:1px solid rgba(255,255,255,.12);border-radius:18px;overflow:hidden;flex-direction:column;box-shadow:0 8px 40px rgba(0,0,0,.7)}
#sp-banner{position:relative;width:100%;overflow:hidden;flex-shrink:0}
#sp-top{position:relative;z-index:1;display:flex;align-items:center;gap:12px;padding:14px 14px 10px}
#sp-art{width:58px;height:58px;border-radius:8px;object-fit:cover;flex-shrink:0;box-shadow:0 4px 20px rgba(0,0,0,.6);background:linear-gradient(135deg,#1db954 0%,#191414 100%);display:flex;align-items:center;justify-content:center;font-size:26px;background-size:cover;background-position:center}
#sp-meta{flex:1;min-width:0}
#sp-tag{display:flex;align-items:center;gap:5px;margin-bottom:4px}
#sp-tag svg{width:11px;height:11px;fill:#1ed760}
#sp-tag span{font-family:var(--ff-head);font-size:9px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#1ed760;opacity:.85}
#sp-bars{display:flex;align-items:flex-end;gap:2px;height:11px;margin-left:auto}
#sp-bars span{width:3px;background:#1ed760;border-radius:2px;animation:sbar 1s ease-in-out infinite}
#sp-bars span:nth-child(1){animation-delay:0s}
#sp-bars span:nth-child(2){animation-delay:.2s}
#sp-bars span:nth-child(3){animation-delay:.4s}
@keyframes sbar{0%,100%{height:3px;opacity:.5}50%{height:11px;opacity:1}}
#sp-title{font-family:var(--ff-head);font-size:14px;font-weight:800;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;letter-spacing:-.01em}
#sp-artist{font-family:var(--ff-body);font-size:12px;font-weight:450;color:rgba(255,255,255,.6);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:2px}
#sp-prog-wrap{padding:0 14px 10px;position:relative;z-index:1}
#sp-prog-bar{height:3px;background:rgba(255,255,255,.12);border-radius:3px;position:relative;overflow:hidden;margin-bottom:4px}
#sp-prog-fill{position:absolute;height:100%;background:#1ed760;border-radius:3px;width:0%;transition:width .5s linear;box-shadow:0 0 6px rgba(30,215,96,.6)}
#sp-times{display:flex;justify-content:space-between;font-family:var(--ff-body);font-size:10px;color:rgba(255,255,255,.35);letter-spacing:.04em}

/* ── LINKS ROW ── */
.links-row{display:flex;gap:8px;justify-content:center;padding:10px 14px;background:rgba(255,255,255,.025);backdrop-filter:blur(30px);border:1px solid rgba(255,255,255,.12);border-radius:14px;box-shadow:0 4px 20px rgba(0,0,0,.3);overflow:visible;position:relative;z-index:10}
.link-btn{width:40px;height:40px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:10px;display:flex;align-items:center;justify-content:center;text-decoration:none;cursor:pointer;transition:all .3s cubic-bezier(.34,1.56,.64,1);position:relative}
.link-btn::before{content:'';position:absolute;inset:0;border-radius:10px;background:linear-gradient(135deg,rgba(255,255,255,.15),transparent);opacity:0;transition:opacity .3s}
.link-btn:hover{transform:translateY(-5px) scale(1.08);border-color:rgba(255,255,255,.3);box-shadow:0 10px 28px rgba(180,160,255,.2)}
.link-btn:hover::before{opacity:1}
.link-btn svg{width:17px;height:17px;fill:rgba(255,255,255,.8);position:relative;z-index:1;transition:fill .2s,transform .3s;backface-visibility:hidden;transform:translateZ(0)}
.link-btn:hover svg{fill:#fff;transform:scale(1.1)}
.views-tip{position:absolute;bottom:calc(100% + 10px);left:50%;transform:translateX(-50%) scale(.9);opacity:0;pointer-events:none;background:rgba(20,20,20,.95);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.15);border-radius:10px;padding:7px 14px;font-family:var(--ff-head);font-size:13px;font-weight:700;color:#fff;white-space:nowrap;box-shadow:0 8px 24px rgba(0,0,0,.6);transition:all .25s cubic-bezier(.34,1.56,.64,1);z-index:9999}
.views-tip::after{content:'';position:absolute;top:100%;left:50%;transform:translateX(-50%);border:6px solid transparent;border-top-color:rgba(255,255,255,.15)}
.views-tip.show{opacity:1;transform:translateX(-50%) scale(1)}

/* ── PLAYER ── */
#player{position:fixed;bottom:0;left:0;right:0;height:var(--player-h);z-index:100;background:rgba(8,8,10,.92);backdrop-filter:blur(20px) saturate(180%);border-top:1px solid rgba(255,255,255,.08);display:flex;align-items:center;box-shadow:0 -8px 40px rgba(0,0,0,.7),0 -1px 0 rgba(255,255,255,.04)}
#player-vis{position:absolute;inset:0;z-index:0;overflow:hidden;opacity:.35}
#player-vis canvas{width:100%;height:100%;display:block}
.player-inner{position:relative;z-index:1;width:100%;height:100%;display:flex;align-items:center;padding:0 20px;gap:16px}
.track-info{min-width:0;flex:0 0 200px}
.track-name{font-family:var(--ff-head);font-size:14px;font-weight:700;color:rgba(255,255,255,.95);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;letter-spacing:.01em}
.track-sub{font-family:var(--ff-body);font-size:11px;font-weight:450;color:rgba(255,255,255,.45);margin-top:2px;letter-spacing:.05em;text-transform:uppercase}
.controls{display:flex;align-items:center;gap:6px}
.ctrl-btn{width:30px;height:30px;background:transparent;border:1px solid rgba(255,255,255,.1);border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s}
.ctrl-btn:hover{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.25);transform:scale(1.06)}
.ctrl-btn svg{width:13px;height:13px;fill:rgba(255,255,255,.85)}
.ctrl-btn.play{width:36px;height:36px;background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.2)}
.ctrl-btn.play svg{width:15px;height:15px}
.ctrl-btn.play:hover{background:rgba(255,255,255,.18);box-shadow:0 0 16px rgba(255,255,255,.15)}
.progress-wrap{flex:1;display:flex;flex-direction:column;gap:5px;min-width:0}
.progress-bar{height:3px;background:rgba(255,255,255,.08);border-radius:3px;cursor:pointer;position:relative;overflow:hidden}
.progress-fill{position:absolute;height:100%;background:linear-gradient(90deg,rgba(180,160,255,.7),rgba(255,255,255,.9));border-radius:3px;width:0%;transition:width .1s linear;box-shadow:0 0 8px rgba(180,160,255,.4)}
.progress-times{display:flex;justify-content:space-between;font-family:var(--ff-body);font-size:9px;font-weight:400;color:rgba(255,255,255,.3);letter-spacing:.05em}
.vol-btn{width:38px;height:38px;background:transparent;border:1px solid rgba(255,255,255,.1);border-radius:10px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;flex-shrink:0}
.vol-btn:hover{background:rgba(255,255,255,.1)}
.vol-btn svg{width:18px;height:18px;fill:rgba(255,255,255,.7)}
.vol-slider-wrap{display:flex;align-items:center;width:120px;height:30px}
#vol-slider{width:100%;height:3px;appearance:none;-webkit-appearance:none;background:rgba(255,255,255,.08);border-radius:3px;outline:none;cursor:pointer;transition:background .2s}
#vol-slider:hover{background:rgba(255,255,255,.12)}
#vol-slider::-webkit-slider-thumb{appearance:none;-webkit-appearance:none;width:14px;height:14px;border-radius:50%;background:linear-gradient(135deg,rgba(180,160,255,.9),rgba(255,255,255,.95));box-shadow:0 0 10px rgba(180,160,255,.4);border:2px solid rgba(255,255,255,.2);transition:transform .2s,box-shadow .2s}
#vol-slider::-webkit-slider-thumb:hover{transform:scale(1.2);box-shadow:0 0 16px rgba(180,160,255,.6)}
#vol-slider::-moz-range-thumb{width:14px;height:14px;border-radius:50%;background:linear-gradient(135deg,rgba(180,160,255,.9),rgba(255,255,255,.95));box-shadow:0 0 10px rgba(180,160,255,.4);border:2px solid rgba(255,255,255,.2);transition:transform .2s,box-shadow .2s}
#vol-slider::-moz-range-thumb:hover{transform:scale(1.2);box-shadow:0 0 16px rgba(180,160,255,.6)}

/* ── PANELS ── */
.panel{position:absolute;background:rgba(255,255,255,.035);backdrop-filter:blur(15px) saturate(160%);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:20px 16px;box-shadow:0 8px 48px rgba(0,0,0,.6),0 0 0 1px rgba(255,255,255,.04) inset,0 1px 0 rgba(255,255,255,.08) inset;display:flex;flex-direction:column;gap:0;z-index:2;pointer-events:none;width:162px;contain:paint}
.panel-sm{position:absolute;background:rgba(255,255,255,.035);backdrop-filter:blur(12px) saturate(160%);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:16px;box-shadow:0 8px 48px rgba(0,0,0,.6),0 0 0 1px rgba(255,255,255,.04) inset,0 1px 0 rgba(255,255,255,.08) inset;display:flex;flex-direction:column;gap:0;z-index:2;pointer-events:none;width:162px;contain:paint}
.side-block{display:flex;flex-direction:column;gap:4px;padding:14px 0}
.side-block:first-child{padding-top:0}
.side-block:last-child{padding-bottom:0}
.side-sep{width:100%;height:1px;background:rgba(255,255,255,.07);flex-shrink:0}
.side-label{font-family:var(--ff-head);font-size:9.5px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.3)}
/* ── RIGHT PANELS ── */
#side-panel{left:calc(50% + 280px)}
#side-time{font-family:var(--ff-head);font-size:16px;font-weight:800;color:rgba(255,255,255,.95);letter-spacing:.02em;text-shadow:0 0 24px rgba(180,160,255,.4);line-height:1;text-transform:uppercase}
#side-tz{font-family:var(--ff-body);font-size:9.5px;font-weight:400;color:rgba(255,255,255,.3);letter-spacing:.1em;margin-top:2px}
#side-age{font-family:var(--ff-head);font-size:12px;font-weight:700;color:rgba(200,185,255,.9);letter-spacing:.03em;text-shadow:0 0 14px rgba(180,160,255,.3)}
#side-last-name{font-family:var(--ff-head);font-size:12px;font-weight:700;color:rgba(255,255,255,.8);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
#side-last-ago{font-family:var(--ff-body);font-size:10px;font-weight:400;color:rgba(255,255,255,.3);margin-top:2px}
.moon-row{display:flex;flex-direction:column;gap:2px;margin-top:4px}
#moon-phase-name{font-family:var(--ff-head);font-size:13px;font-weight:800;color:rgba(255,255,255,.9);letter-spacing:-.01em}
#moon-illum{font-family:var(--ff-body);font-size:10px;color:rgba(255,255,255,.4)}

/* ── LEFT PANELS ── */
#left-panel{right:calc(50% + 280px)}
.tags-wrap{display:flex;flex-wrap:wrap;gap:5px}
.tag{font-family:var(--ff-body);font-size:10px;font-weight:500;color:rgba(200,185,255,.85);background:rgba(180,160,255,.08);border:1px solid rgba(180,160,255,.2);border-radius:20px;padding:3px 8px;line-height:1.4;white-space:nowrap}

/* lang panel */
#lang-panel{right:calc(50% + 280px)}
.lang-row{display:flex;flex-direction:column;gap:8px}
.lang-item{display:flex;align-items:center;gap:9px}
.flag-box{width:22px;height:15px;border-radius:2px;flex-shrink:0;overflow:hidden;display:flex;flex-direction:column}
.flag-stripe{flex:1}
.lang-name{font-family:var(--ff-head);font-size:12px;font-weight:700;color:rgba(255,255,255,.85)}
.lang-level{font-family:var(--ff-body);font-size:9.5px;color:rgba(255,255,255,.35);margin-top:1px}

/* zodiac */
#zodiac-card{left:calc(50% + 280px)}
#zodiac-sign-name{font-family:var(--ff-head);font-size:22px;font-weight:800;color:rgba(255,255,255,.95);letter-spacing:-.02em;text-shadow:0 0 20px rgba(180,160,255,.35)}
#zodiac-dates{font-family:var(--ff-body);font-size:10px;color:rgba(255,255,255,.35);margin-top:2px}
#zodiac-trait{font-family:var(--ff-body);font-size:10.5px;font-weight:400;font-style:italic;color:rgba(255,255,255,.45);line-height:1.5;margin-top:6px}

/* takbir */
#takbir-card{right:calc(50% + 280px);text-align:center;align-items:center;justify-content:center;gap:5px}
#takbir-arabic{font-size:20px;font-weight:700;color:rgba(255,255,255,.95);text-shadow:0 0 20px rgba(180,160,255,.5);line-height:1.5;direction:rtl}
#takbir-latin{font-family:var(--ff-body);font-size:10px;font-weight:400;color:rgba(255,255,255,.3);letter-spacing:.14em;text-transform:uppercase}

/* USA flag */
.flag-usa{width:22px;height:15px;border-radius:2px;flex-shrink:0;overflow:hidden;position:relative;background:repeating-linear-gradient(to bottom,#B22234 0,#B22234 calc(100%/13),#fff calc(100%/13),#fff calc(200%/13))}
.flag-usa::before{content:'';position:absolute;top:0;left:0;width:40%;height:calc(700%/13);background:#3C3B6E}

/* ── HIDE SIDE PANELS ON SMALL SCREENS ── */
@media(max-width:1060px){#side-panel,#left-panel,#zodiac-card,#lang-panel,#takbir-card{display:none!important}}
@media(max-width:520px){#content{max-width:94vw}.profile-name{font-size:20px}.track-info{flex:0 0 130px}.progress-times{display:none}.mobile-br{display:block}.quote-text{white-space:normal}}

/* ── CURSOR TRAIL ── */
.cur-dot{position:fixed;pointer-events:none;z-index:99999;border-radius:50%;transform:translate(-50%,-50%);will-change:transform,opacity}

/* ── TOP LEFT VOLUME CONTROL ── */
#volume-control{
  position: fixed;
  top: 20px;
  left: 20px;
  z-index: 1000;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  background: rgba(255,255,255,.035);
  backdrop-filter: blur(15px) saturate(160%);
