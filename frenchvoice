local FAVORITES_FILE = "OutfitExplorer_Favorites.json"
local Favorites = {}

local function saveFavorites()
    if writefile then pcall(function() writefile(FAVORITES_FILE, HttpService:JSONEncode(Favorites)) end) end
end

local function loadFavorites()
    if readfile and isfile and isfile(FAVORITES_FILE) then
        local success, result = pcall(function() return HttpService:JSONDecode(readfile(FAVORITES_FILE)) end)
        if success and type(result) == "table" then Favorites = result end
    end
end
