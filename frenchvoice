local function createOutfitCard(outfit, isFavCard)
    local Card = Instance.new("Frame")
    Card.Size = UDim2.new(1, -8, 0, 100)
    Card.BackgroundColor3 = Theme.CardBg
    Card.BackgroundTransparency = 0.3
    Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 14)

    local CardStroke = Instance.new("UIStroke", Card)
    CardStroke.Color = Theme.Border
    CardStroke.Thickness = 1.5

    local ImgBg = Instance.new("Frame", Card)
    ImgBg.Size = UDim2.new(0, 80, 0, 80)
    ImgBg.Position = UDim2.new(0, 10, 0.5, -40)
    ImgBg.BackgroundColor3 = Theme.WindowBg
    Instance.new("UICorner", ImgBg).CornerRadius = UDim.new(0, 12)

    local Img = Instance.new("ImageLabel", ImgBg)
    Img.Size = UDim2.new(1, -4, 1, -4)
    Img.Position = UDim2.new(0.5, 0, 0.5, 0)
    Img.AnchorPoint = Vector2.new(0.5, 0.5)
    Img.Image = "rbxthumb://type=Outfit&id=" .. outfit.id .. "&w=150&h=150"
    Img.BackgroundTransparency = 1
    Instance.new("UICorner", Img).CornerRadius = UDim.new(0, 10)

    local Name = Instance.new("TextLabel", Card)
    Name.Size = UDim2.new(1, -210, 0, 26)
    Name.Position = UDim2.new(0, 105, 0, 22)
    Name.BackgroundTransparency = 1
    Name.Text = outfit.name
    Name.TextColor3 = Theme.TextTitle
    Name.Font = Enum.Font.GothamBold
    Name.TextSize = 16
    Name.TextXAlignment = Enum.TextXAlignment.Left

    local Id = Instance.new("TextLabel", Card)
    Id.Size = UDim2.new(1, -210, 0, 18)
    Id.Position = UDim2.new(0, 105, 0, 52)
    Id.BackgroundTransparency = 1
    Id.Text = "ID: " .. outfit.id
    Id.TextColor3 = Theme.TextMuted
    Id.Font = Enum.Font.Gotham
    Id.TextSize = 13
    Id.TextXAlignment = Enum.TextXAlignment.Left

    local BtnContainer = Instance.new("Frame", Card)
    BtnContainer.Size = UDim2.new(0, 95, 1, -20)
    BtnContainer.Position = UDim2.new(1, -105, 0, 10)
    BtnContainer.BackgroundTransparency = 1

    local List = Instance.new("UIListLayout", BtnContainer)
    List.Padding = UDim.new(0, 8)
    List.VerticalAlignment = Enum.VerticalAlignment.Center

    local function createBtn(text, color, isSolid)
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(1, 0, 0, 34)
        b.BackgroundColor3 = color
        b.Text = text
        b.TextColor3 = Theme.Text
        b.Font = Enum.Font.GothamBold
        b.TextSize = 13
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)
        if not isSolid then
            b.BackgroundTransparency = 1
            local s = Instance.new("UIStroke", b)
            s.Color = color; s.Thickness = 1.5
        end
        b.MouseEnter:Connect(function() TweenService:Create(b, TInfoFast, {BackgroundColor3 = isSolid and Theme.AccentHover or color, BackgroundTransparency = 0}):Play() end)
        b.MouseLeave:Connect(function() TweenService:Create(b, TInfoFast, {BackgroundColor3 = color, BackgroundTransparency = isSolid and 0 or 1}):Play() end)
        return b
    end

    local ActionBtn = createBtn(isFavCard and "Remove" or "Copy", isFavCard and Theme.Danger or Theme.Accent, false)
    ActionBtn.Parent = BtnContainer
    local WearBtn = createBtn("Wear", Theme.Accent, true)
    WearBtn.Parent = BtnContainer

    ActionBtn.MouseButton1Click:Connect(function()
        if isFavCard then
            for i, v in ipairs(Favorites) do if v.id == outfit.id then table.remove(Favorites, i) break end end
            saveFavorites()
            TweenService:Create(Card, TInfoSmooth, {Size = UDim2.new(1,-8,0,0), BackgroundTransparency = 1}):Play()
            task.wait(0.3); Card:Destroy()
            StatusLabel.Text = #Favorites .. " favoris restants"
        else
            setclipboard(tostring(outfit.id))
            ActionBtn.Text = "★ Saved"
            ActionBtn.TextColor3 = Theme.Success
            local s = ActionBtn:FindFirstChildOfClass("UIStroke")
            if s then s.Color = Theme.Success end

            local exists = false
            for _, v in ipairs(Favorites) do if v.id == outfit.id then exists = true break end end
            if not exists then table.insert(Favorites, 1, {id = outfit.id, name = outfit.name}); saveFavorites() end

            task.wait(1.5); ActionBtn.Text = "Copy"; ActionBtn.TextColor3 = Theme.Text
            if s then s.Color = Theme.Accent end
        end
    end)

    WearBtn.MouseButton1Click:Connect(function()
        local args = {buffer.fromstring("\005\000"), {tonumber(outfit.id)}}
        local remote = game:GetService("ReplicatedStorage"):FindFirstChild("BLINK_RELIABLE_REMOTE")
        if remote then remote:FireServer(unpack(args)) end
    end)

    Card.MouseEnter:Connect(function()
        TweenService:Create(Card, TInfoFast, {BackgroundColor3 = Theme.CardHover, BackgroundTransparency = 0.1}):Play()
        TweenService:Create(CardStroke, TInfoFast, {Color = Theme.Accent}):Play()
    end)
    Card.MouseLeave:Connect(function()
        TweenService:Create(Card, TInfoFast, {BackgroundColor3 = Theme.CardBg, BackgroundTransparency = 0.3}):Play()
        TweenService:Create(CardStroke, TInfoFast, {Color = Theme.Border}):Play()
    end)

    return Card
end

