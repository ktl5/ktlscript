-- ║     TOOL RESPAWN (mort / reset)      ║
-- ╚══════════════════════════════════════╝
local function setupTool()
    if LocalPlayer.Backpack:FindFirstChild(ToolName) then
        LocalPlayer.Backpack[ToolName]:Destroy()
    end
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(ToolName) then
        LocalPlayer.Character[ToolName]:Destroy()
    end

    local toolClone = ScannerTool:Clone()
    toolClone.Parent = LocalPlayer.Backpack

    toolClone.Equipped:Connect(function()   isToolEquipped = true  end)
    toolClone.Unequipped:Connect(function() isToolEquipped = false end)

    toolClone.Activated:Connect(function()
        if not isToolEquipped then return end

        local camera = workspace.CurrentCamera
        local unitRay = camera:ScreenPointToRay(Mouse.X, Mouse.Y)
        local rayParams = RaycastParams.new()
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        if LocalPlayer.Character then
            rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
        end

        local result = workspace:Raycast(unitRay.Origin, unitRay.Direction * 1000, rayParams)
        local foundPlayer = nil

        if result and result.Instance then
            local hit = result.Instance
            local current = hit
            while current and current ~= workspace do
                local plr = Players:GetPlayerFromCharacter(current)
                if plr and plr ~= LocalPlayer then foundPlayer = plr; break end
                current = current.Parent
            end
        end

        if not foundPlayer then
            local target = Mouse.Target
            if target then
                local current = target
                while current and current ~= workspace do
                    local plr = Players:GetPlayerFromCharacter(current)
                    if plr and plr ~= LocalPlayer then foundPlayer = plr; break end
                    current = current.Parent
                end
            end
        end

        if not foundPlayer then
            local hitPos = Mouse.Hit and Mouse.Hit.Position
            if hitPos then
                local closestDist = 15
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LocalPlayer and plr.Character then
                        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local dist = (hrp.Position - hitPos).Magnitude
                            if dist < closestDist then
                                closestDist = dist
                                foundPlayer = plr
                            end
                        end
                    end
                end
            end
        end

        if foundPlayer then
            loadPlayerOutfits(foundPlayer)
        else
            StatusLabel.Text = "Aucun joueur détecté — réessayez"
        end
    end)
end

setupTool()

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    setupTool()
end)

