local function loadPlayerOutfits(targetPlayer)
    if isLoading then return end

    if not isGuiOpen then toggleUI(true) end
    if isMinimized then minBtn.MouseButton1Click:Fire() end

    local cached = outfitCache[targetPlayer.UserId]
    if cached and (os.time() - cached.timestamp) < CACHE_EXPIRY then
        clearUI()
        TitleLabel.Text = cached.playerName or targetPlayer.Name
        StatusLabel.Text = #cached.data .. " outfit(s) • cache"
        renderOutfits(cached.data, false)
        return
    end

    isLoading = true
    clearUI()
    TitleLabel.Text = targetPlayer.Name
    startSpinner(StatusLabel)

    task.spawn(function()
        local url = ("https://avatar.roproxy.com/v1/users/%d/outfits?itemsPerPage=50"):format(targetPlayer.UserId)
        local success, result = pcall(function() return game:HttpGet(url) end)

        stopSpinner()
        isLoading = false

        if not success then
            StatusLabel.Text = "❌ Erreur réseau — réessayez"
            TitleLabel.Text = "Outfit Explorer Pro"
            return
        end

        local ok, data = pcall(function() return HttpService:JSONDecode(result) end)
        if not ok or not data or not data.data then
            StatusLabel.Text = "❌ Données invalides"
            TitleLabel.Text = "Outfit Explorer Pro"
            return
        end

        outfitCache[targetPlayer.UserId] = {
            data       = data.data,
            timestamp  = os.time(),
            playerName = targetPlayer.Name,
        }

        TitleLabel.Text = targetPlayer.Name
        StatusLabel.Text = #data.data .. " outfit(s) trouvés"
        renderOutfits(data.data, false)
    end)
end

