local outfitCache   = {}
local isLoading     = false
local CACHE_EXPIRY  = 120

local function clearUI()
    for _, v in ipairs(Scroll:GetChildren()) do
        if v:IsA("Frame") or v:IsA("TextLabel") then v:Destroy() end
    end
end

local spinnerChars = {"⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"}
local spinnerConn  = nil
local function startSpinner(label)
    local i = 1
    if spinnerConn then spinnerConn:Disconnect() end
    spinnerConn = RunService.Heartbeat:Connect(function()
        i = (i % #spinnerChars) + 1
        label.Text = spinnerChars[i] .. "  Chargement..."
    end)
end
local function stopSpinner()
    if spinnerConn then spinnerConn:Disconnect(); spinnerConn = nil end
end

local function renderOutfits(outfitList, isFav)
    local BATCH = 10
    for i, outfit in ipairs(outfitList) do
        createOutfitCard(outfit, isFav).Parent = Scroll
        if i % BATCH == 0 then RunService.Heartbeat:Wait() end
    end
end

-- ╔══════════════════════════════════════╗
-- ║   RÉSOLUTION USERNAME → USER ID      ║
-- ╚══════════════════════════════════════╝
-- Retourne userId (number), playerName (string) ou nil, errMsg (string)
local function resolveInput(raw)
    -- Cas 1 : c'est déjà un ID numérique
    local asNumber = tonumber(raw)
    if asNumber then
        -- On vérifie quand même que l'ID existe et récupère le vrai nom
        local ok, res = pcall(function()
            return game:HttpGet(("https://users.roproxy.com/v1/users/%d"):format(asNumber))
        end)
        if not ok then
            return nil, "❌ Erreur réseau — ID introuvable"
        end
        local parseOk, data = pcall(function() return HttpService:JSONDecode(res) end)
        if not parseOk or not data or not data.id then
            return nil, "❌ ID introuvable sur Roblox"
        end
        return data.id, data.name or ("ID " .. asNumber)
    end

    -- Cas 2 : username → on essaie plusieurs endpoints GET avec fallback
    local encoded = HttpService:UrlEncode(raw)
    local userId, playerName = nil, nil

    -- Tentative 1 : search endpoint (retourne une liste, on cherche le match exact)
    local ok1, res1 = pcall(function()
        return game:HttpGet(
            "https://users.roproxy.com/v1/users/search?keyword=" .. encoded .. "&limit=10"
        )
    end)
    if ok1 then
        local p1, d1 = pcall(function() return HttpService:JSONDecode(res1) end)
        if p1 and d1 and d1.data then
            for _, u in ipairs(d1.data) do
                if u.name:lower() == raw:lower() then
                    userId = u.id
                    playerName = u.name
                    break
                end
            end
        end
    end

    -- Tentative 2 : ancien endpoint api.roblox (toujours actif via proxy)
    if not userId then
        local ok2, res2 = pcall(function()
            return game:HttpGet(
                "https://api.roproxy.com/users/get-by-username?username=" .. encoded
            )
        end)
        if ok2 then
            local p2, d2 = pcall(function() return HttpService:JSONDecode(res2) end)
            if p2 and d2 and d2.Id and d2.Id ~= 0 then
                userId = d2.Id
                playerName = d2.Username
            end
        end
    end

    -- Tentative 3 : endpoint roblox.com direct
    if not userId then
        local ok3, res3 = pcall(function()
            return game:HttpGet(
                "https://www.roproxy.com/users/get-by-username?username=" .. encoded
            )
        end)
        if ok3 then
            local p3, d3 = pcall(function() return HttpService:JSONDecode(res3) end)
            if p3 and d3 and d3.Id and d3.Id ~= 0 then
                userId = d3.Id
                playerName = d3.Username
            end
        end
    end

    if not userId then
        return nil, "❌ Joueur « " .. raw .. " » introuvable"
    end
    return userId, playerName
end

-- ╔══════════════════════════════════════╗
-- ║   LOAD PAR ID OU USERNAME            ║
-- ║   (coeur du système de recherche)    ║
-- ╚══════════════════════════════════════╝
local function loadOutfitsByUserId(raw)
    if isLoading then return end

    if not isGuiOpen then toggleUI(true) end
    if isMinimized then minBtn.MouseButton1Click:Fire() end

    isLoading = true
    clearUI()
    TitleLabel.Text = "Recherche..."
    startSpinner(StatusLabel)
    SearchBtn.Active = false
    SearchBtn.BackgroundColor3 = Theme.Border

    local function onError(msg)
        stopSpinner()
        isLoading = false
        SearchBtn.Active = true
        SearchBtn.BackgroundColor3 = Theme.Accent
        StatusLabel.Text = msg
        TitleLabel.Text = "Outfit Explorer Pro"
        TweenService:Create(SearchStroke, TInfoSmooth, {Color = Theme.Danger}):Play()
        task.delay(2, function() TweenService:Create(SearchStroke, TInfoSmooth, {Color = Theme.Border}):Play() end)
    end

    task.spawn(function()
        -- 1) Résoudre l'input (ID ou username) → userId + playerName
        local userId, playerName = resolveInput(raw)
        if not userId then
            onError(playerName) -- playerName contient le message d'erreur dans ce cas
            return
        end

        -- 2) Cache hit (après résolution)
        local cached = outfitCache[userId]
        if cached and (os.time() - cached.timestamp) < CACHE_EXPIRY then
            stopSpinner()
            isLoading = false
            SearchBtn.Active = true
            SearchBtn.BackgroundColor3 = Theme.Accent
            TitleLabel.Text = cached.playerName or playerName
            StatusLabel.Text = #cached.data .. " outfit(s) • cache"
            renderOutfits(cached.data, false)
            return
        end

        -- 3) Charger les outfits
        TitleLabel.Text = playerName
        local outfitUrl = ("https://avatar.roproxy.com/v1/users/%d/outfits?itemsPerPage=50"):format(userId)
        local success, result = pcall(function() return game:HttpGet(outfitUrl) end)

        stopSpinner()
        isLoading = false
        SearchBtn.Active = true
        SearchBtn.BackgroundColor3 = Theme.Accent

        if not success then
            onError("❌ Erreur lors du chargement des outfits")
            return
        end

        local ok, data = pcall(function() return HttpService:JSONDecode(result) end)
        if not ok or not data or not data.data then
            onError("❌ Données invalides pour " .. playerName)
            return
        end

        outfitCache[userId] = {
            data       = data.data,
            timestamp  = os.time(),
            playerName = playerName,
        }

        TitleLabel.Text = playerName
        StatusLabel.Text = #data.data .. " outfit(s) trouvés"

        if #data.data == 0 then
            local empty = Instance.new("TextLabel", Scroll)
            empty.Size = UDim2.new(1, 0, 0, 100)
            empty.BackgroundTransparency = 1
            empty.Text = playerName .. " n'a aucun outfit public."
            empty.TextColor3 = Theme.TextMuted
            empty.Font = Enum.Font.GothamMedium
            empty.TextSize = 14
        else
            renderOutfits(data.data, false)
        end
    end)
end

-- Déclencher la recherche via le bouton ou la touche Entrée
local function triggerSearch()
    local raw = SearchBox.Text:match("^%s*(.-)%s*$") -- trim whitespace
    if raw == "" then
        StatusLabel.Text = "⚠ Entrez un ID ou un username"
        return
    end
    loadOutfitsByUserId(raw)
end

SearchBtn.MouseButton1Click:Connect(triggerSearch)

SearchBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then triggerSearch() end
end)

