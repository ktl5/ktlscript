local function applyVisuals(p)
    if p == LocalPlayer then return end
    local char = p.Character
    if not char then return end

    -- Highlight Logic (Chams / Outline)
    local highlight = char:FindFirstChild("KTL_Highlight")
    if not highlight then
        highlight = Instance.new("Highlight")
        highlight.Name = "KTL_Highlight"
        highlight.Parent = char
    end

    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillColor = Color3.fromRGB(255, 255, 255)

    if visualsConfig.Chams then
        highlight.Enabled = true
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
    elseif visualsConfig.Outline then
        highlight.Enabled = true
        highlight.FillTransparency = 1
        highlight.OutlineTransparency = 0
    else
        highlight.Enabled = false
    end

    -- ESP Logic (Name)
    local head = char:FindFirstChild("Head")
    if head then
        local espGui = head:FindFirstChild("KTL_ESP")
        if not espGui then
            espGui = Instance.new("BillboardGui")
            espGui.Name = "KTL_ESP"
            espGui.Adornee = head
            espGui.Size = UDim2.new(0, 100, 0, 50)
            espGui.StudsOffset = Vector3.new(0, 2, 0)
            espGui.AlwaysOnTop = true
            espGui.Parent = head

            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, 0, 1, 0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = p.DisplayName or p.Name
            nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            nameLabel.TextStrokeTransparency = 0
            nameLabel.TextSize = 14
            nameLabel.Font = Enum.Font.SourceSansBold
            nameLabel.Parent = espGui
        end
        espGui.Enabled = visualsConfig.ESP
    end
end

