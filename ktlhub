-- Onglet Paramètres
win:switchTab(settingsTab)
win:addToggle("Dark Mode", true, function(state)
    updateUITheme(state)
end)

win:switchTab(mainTab)

-- Keybinds rapides
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if UserInputService:GetFocusedTextBox() then return end

    -- F = Toggle Fly
    if input.KeyCode == Enum.KeyCode.F then
        local newState = not flying
        flyToggleObj.set(newState) -- met à jour l’UI + déclenche le callback
    end

    -- G = Toggle Noclip
    if input.KeyCode == Enum.KeyCode.G then
        local newState = not noclipMode
        noclipToggleObj.set(newState)
    end

    -- H = Toggle NoclipCam
    if input.KeyCode == Enum.KeyCode.H then
        local newState = not noclipCamMode
        noclipCamToggleObj.set(newState)
    end
end)
