-- LOGIQUE INVISIBILITÉ (NUCLEARBOBO 5.0.4 LOGIC)
-------------------------------------------------------------------------
local function applyTransparencyLoop()
    if not isInvisible or not character then return end

    for _, obj in pairs(character:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name ~= "HumanoidRootPart" then
            if originalTransparencies[obj] == nil then
                originalTransparencies[obj] = obj.Transparency
            end
            if obj.Transparency ~= invisibilityConfig.Transparency then
                obj.Transparency = invisibilityConfig.Transparency
            end
        elseif obj:IsA("Decal") then
            if obj.Transparency ~= invisibilityConfig.Transparency then
                obj.Transparency = invisibilityConfig.Transparency
            end
        end
    end
end

function toggleInvisibility(state)
    if not character or not character.Parent then setupCharacter() end
    isInvisible = state

    if not isInvisible then
        -- Restauration des transparences
        for obj, trans in pairs(originalTransparencies) do
            if obj and obj.Parent then
                obj.Transparency = trans
            end
        end
        for _, obj in pairs(character:GetDescendants()) do
            if obj:IsA("Decal") then obj.Transparency = 0 end
        end
        win:notify("Invisibility", "Disabled")
    else
        win:notify("Invisibility", "Enable")
    end
end

-- Boucle de téléportation pour l'invisibilité
RunService.Heartbeat:Connect(function()
    if isInvisible and character and rootPart and humanoid and rootPart.Parent then
        applyTransparencyLoop()

        local oldCF = rootPart.CFrame
        local oldOffset = humanoid.CameraOffset
        local hiddenCF = oldCF * CFrame.new(0, invisibilityConfig.TeleportHeight, 0)

        -- Désactivation temporaire des forces du Fly pour éviter l'explosion physique
        local oldMaxForce = nil
        if flying and pos then
            oldMaxForce = pos.MaxForce
            pos.MaxForce = Vector3.new(0, 0, 0)
        end

        rootPart.CFrame = hiddenCF
        humanoid.CameraOffset = Vector3.new(0, -invisibilityConfig.TeleportHeight, 0)

        RunService.RenderStepped:Wait()

        if rootPart and rootPart.Parent then
            local currentPos = rootPart.Position
            local expectedPos = hiddenCF.Position

            -- Anti-Rollback TP: Si on a bougé de plus de 50 studs (ex: TP), on accepte la nouvelle position
            if (currentPos - expectedPos).Magnitude > 50 then
                oldCF = rootPart.CFrame
            end

            rootPart.CFrame = oldCF
            humanoid.CameraOffset = oldOffset

            -- Restauration des forces du Fly
            if flying and pos and oldMaxForce then
                pos.MaxForce = oldMaxForce
            end
        end
    end
end)

