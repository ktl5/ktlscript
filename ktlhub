-- Table pour stocker les objets UI afin de pouvoir les mettre à jour
local uiElements = {
    Toggles = {},
    Sliders = {}
}

-- Table pour stocker les callbacks originaux (pour forcer la mise à jour)
local uiCallbacks = {
    Toggles = {},
    Sliders = {}
}

local function saveCurrentPresets()
    if writefile then
        writefile(presetFileName, HttpService:JSONEncode(currentPresets))
    end
end

local function loadGlobalPresets()
    if isfile and isfile(presetFileName) then
        local content = readfile(presetFileName)
        local success, data = pcall(HttpService.JSONDecode, HttpService, content)
        if success then
            currentPresets = data
            -- Application des valeurs chargées aux éléments UI existants
            for name, state in pairs(currentPresets.Toggles) do
                if uiElements.Toggles[name] then
                    pcall(function()
                        uiElements.Toggles[name].set(state)
                        if uiCallbacks.Toggles[name] then
                            uiCallbacks.Toggles[name](state)
                        end
                    end)
                end
            end
            for name, value in pairs(currentPresets.Sliders) do
                if uiElements.Sliders[name] then
                    pcall(function()
                        uiElements.Sliders[name].set(value)
                        if uiCallbacks.Sliders[name] then
                            uiCallbacks.Sliders[name](value)
                        end
                    end)
                end
            end
        end
    end
end

