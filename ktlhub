local function detectWeaponColor(player)
    local character = player.Character
    if not character then return MM2_DEFAULT_COLOR end

    local best, bestPrio = nil, 0
    local weaponKeywords = {
        { pattern = "gun", priority = 2, color = MM2_GUN_COLOR },
        { pattern = "knife", priority = 1, color = MM2_KNIFE_COLOR },
    }

    local function checkTool(tool)
        if not tool:IsA("Tool") then return end
        local lower = tool.Name:lower()
        for _, entry in ipairs(weaponKeywords) do
            if lower:find(entry.pattern) and entry.priority > bestPrio then
                bestPrio = entry.priority
                best = entry.color
            end
        end
    end

    for _, obj in ipairs(character:GetChildren()) do checkTool(obj) end
    local bp = player:FindFirstChildOfClass("Backpack")
    if bp then for _, obj in ipairs(bp:GetChildren()) do checkTool(obj) end end

    return best or MM2_DEFAULT_COLOR
end

local function updateMM2PlayerVisuals(p)
    if p == LocalPlayer then return end
    local char = p.Character
    if not char then return end

    local color = detectWeaponColor(p)

    -- Player Outline (Highlight)
    local highlight = char:FindFirstChild("MM2_Highlight")
    if mm2Config.PlayerOutline then
        if not highlight then
            highlight = Instance.new("Highlight")
            highlight.Name = "MM2_Highlight"
            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            highlight.FillTransparency = 0.5
            highlight.OutlineTransparency = 0
            highlight.Parent = char
        end
        highlight.FillColor = color
        highlight.OutlineColor = color
        highlight.Enabled = true
    elseif highlight then
        highlight.Enabled = false
    end

    -- Player ESP (BillboardGui)
    local head = char:FindFirstChild("Head")
    if head then
        local espGui = head:FindFirstChild("MM2_ESP")
        if mm2Config.PlayerESP then
            if not espGui then
                espGui = Instance.new("BillboardGui")
                espGui.Name = "MM2_ESP"
                espGui.Adornee = head
                espGui.Size = UDim2.new(0, 140, 0, 26)
                espGui.StudsOffset = Vector3.new(0, 2.6, 0)
                espGui.AlwaysOnTop = true
                espGui.Parent = head

                local label = Instance.new("TextLabel")
                label.Name = "NameLabel"
                label.Size = UDim2.new(1, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.Text = p.DisplayName or p.Name
                label.TextColor3 = color
                label.TextSize = 13
                label.Font = Enum.Font.GothamBold
                label.Parent = espGui
            end
            local label = espGui:FindFirstChild("NameLabel")
            if label then label.TextColor3 = color end
            espGui.Enabled = true
        elseif espGui then
            espGui.Enabled = false
        end
    end
end

local function updateAllMM2Visuals()
    for _, p in pairs(Players:GetPlayers()) do
        updateMM2PlayerVisuals(p)
    end
end

local function updateDroppedGunESP()
    local map = getMap()
    if mm2Config.DroppedGunESP and map then
        local gun = map:FindFirstChild("GunDrop")
        if gun then
            local highlight = gun:FindFirstChild("KTL_GunHighlight")
            if not highlight then
