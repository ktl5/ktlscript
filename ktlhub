local function updateDroppedGunESP()
    local map = getMap()
    if mm2Config.DroppedGunESP and map then
        local gun = map:FindFirstChild("GunDrop")
        if gun then
            -- Highlight Logic
            local highlight = gun:FindFirstChild("KTL_GunHighlight")
            if not highlight then
                highlight = Instance.new("Highlight")
                highlight.Name = "KTL_GunHighlight"
                highlight.FillColor = Color3.fromRGB(255, 255, 0)
                highlight.FillTransparency = 0.5
                highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                highlight.Parent = gun
            end
            
            -- ESP Logic (Name)
            local espGui = gun:FindFirstChild("KTL_GunESP")
            if not espGui then
                espGui = Instance.new("BillboardGui")
                espGui.Name = "KTL_GunESP"
                espGui.AlwaysOnTop = true
                espGui.Size = UDim2.new(0, 100, 0, 50)
                espGui.StudsOffset = Vector3.new(0, 2, 0)
                espGui.Parent = gun

                local label = Instance.new("TextLabel")
                label.Size = UDim2.new(1, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.Text = "GUN"
                label.TextColor3 = Color3.fromRGB(255, 255, 0)
                label.TextStrokeTransparency = 0
                label.TextSize = 14
                label.Font = Enum.Font.GothamBold
                label.Parent = espGui
            end
        else
            -- Clear old ESP if gun is gone
            if map then
                for _, child in pairs(map:GetChildren()) do
                    if child.Name == "GunDrop" then
                        local h = child:FindFirstChild("KTL_GunHighlight")
                        if h then h:Destroy() end
                        local e = child:FindFirstChild("KTL_GunESP")
                        if e then e:Destroy() end
                    end
                end
            end
        end
    end
end

