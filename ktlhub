local function muteSound(child)
    if child:IsA("Sound") then
        local function check()
            local soundId = tostring(child.SoundId)
            if soundId:find("3023237993") or soundId:find("6023426111") then
                child.Volume = 0
                child:Stop()
                task.defer(function() child:Destroy() end)
            end
        end
        check()
        child:GetPropertyChangedSignal("SoundId"):Connect(check)
    end
end

