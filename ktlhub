UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if UserInputService:GetFocusedTextBox() then return end

    if input.KeyCode == Enum.KeyCode.F then
        local newState = not flying
        flyToggleObj.set(newState)
    end

    if input.KeyCode == Enum.KeyCode.G then
        local newState = not noclipMode
        noclipToggleObj.set(newState)
    end

    if input.KeyCode == Enum.KeyCode.CapsLock then
        local newState = not noclipCamMode
        noclipCamToggleObj.set(newState)
    end

    if input.KeyCode == Enum.KeyCode.T then
        win:minimize()
    end

    if input.KeyCode == Enum.KeyCode.X then
        local newState = not isInvisible
        invisibleToggleObj.set(newState)
    end

    if clickTPEnabled and input.UserInputType == Enum.UserInputType.MouseButton1 and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        local mouse = LocalPlayer:GetMouse()
        if mouse.Target and not mouse.Target:IsDescendantOf(character) and rootPart then
            local oldPos = rootPart.Position
            local hitPos = mouse.Hit.Position

            local rayParam = RaycastParams.new()
            rayParam.FilterDescendantsInstances = {character}
            rayParam.FilterType = Enum.RaycastFilterType.Exclude

            local rayResult = workspace:Raycast(hitPos + Vector3.new(0, 10, 0), Vector3.new(0, -20, 0), rayParam)

            local finalPos
            if rayResult then
                finalPos = rayResult.Position + Vector3.new(0, 3.5, 0)
            else
                finalPos = hitPos + Vector3.new(0, 3.5, 0)
            end

            local direction = (finalPos - oldPos).Unit

            if (finalPos - oldPos).Magnitude > 0.1 then
                local lookTarget = finalPos + Vector3.new(direction.X, 0, direction.Z)
                rootPart.CFrame = CFrame.lookAt(finalPos, lookTarget)

                if flying and gyro then
                    gyro.CFrame = rootPart.CFrame
                end
            else
                rootPart.CFrame = CFrame.new(finalPos)
            end
        end
    end
end)
