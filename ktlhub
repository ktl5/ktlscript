-- LOGIQUE FLY
-------------------------------------------------------------------------
function startFlying()
    if flying or not rootPart then return end
    flying = true
    
    pos = Instance.new("BodyPosition")
    gyro = Instance.new("BodyGyro")

    -- Fix: Si on est invisible, on ne prend pas la position actuelle (qui peut être à -5000)
    -- On calcule la position de surface correcte
    local targetInitialPos = rootPart.Position
    if isInvisible then
        targetInitialPos = targetInitialPos + Vector3.new(0, -invisibilityConfig.TeleportHeight, 0)
    end

    pos.Position = targetInitialPos + Vector3.new(0, 3, 0)
    pos.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    pos.P = 55000
    pos.D = 1400

    gyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    gyro.P = 20000
    gyro.D = 800

    pos.Parent = rootPart
    gyro.Parent = rootPart
    humanoid.PlatformStand = true

    heartbeatEvent = RunService.Heartbeat:Connect(function(dt)
        if not flying or not pos or not gyro or not rootPart then return end
        if UserInputService:GetFocusedTextBox() then return end

        -- Anti-Rollback: Si la distance entre le perso et la position cible du fly est trop grande (TP), on synchronise
        if (rootPart.Position - pos.Position).Magnitude > 25 then
            pos.Position = rootPart.Position
        end

        local cam = workspace.CurrentCamera
        local moveDir = humanoid.MoveDirection
        local frameSpeed = flySpeed * 5 * FlyMultiplier * (dt * 60)
        local dir = cam.CFrame:VectorToObjectSpace(moveDir * frameSpeed)

        if dir.Magnitude > 0 then
            pos.Position = pos.Position + cam.CFrame:VectorToWorldSpace(Vector3.new(dir.X, 0, dir.Z).Unit * dir.Magnitude)
        end

        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            pos.Position = pos.Position + Vector3.new(0, frameSpeed, 0)
        elseif UserInputService:IsKeyDown(Enum.KeyCode.Q) then
            pos.Position = pos.Position - Vector3.new(0, frameSpeed, 0)
        end

        gyro.CFrame = gyro.CFrame:Lerp(cam.CFrame, 0.3)
        humanoid.PlatformStand = true
    end)
end

function stopFlying()
    flying = false
    if heartbeatEvent then heartbeatEvent:Disconnect() end
    if pos then pos:Destroy() end
    if gyro then gyro:Destroy() end
    if humanoid then
        humanoid.PlatformStand = false
        humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
    end
end

