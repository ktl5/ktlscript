            flingDiedConn = hum.Died:Connect(function()
                if flingEnabled then
                    flingEnabled = false
                end
            end)
        end

        task.spawn(function()
            while flingEnabled and rootPart and flingBodyAV do
                if flingBodyPos then
                    flingBodyPos.Position = Vector3.new(0, rootPart.Position.Y, 0)
                end

                rootPart.Velocity = Vector3.new(0, 0, 0)
                for _, child in pairs(character:GetDescendants()) do
                    if child:IsA("BasePart") then
                        child.CanCollide = false
                    end
                end

                flingBodyAV.AngularVelocity = Vector3.new(0, 99999, 0)
                task.wait(0.2)
                if not flingEnabled or not flingBodyAV then break end
                flingBodyAV.AngularVelocity = Vector3.new(0, 0, 0)
                task.wait(0.1)
            end
        end)
    else
        flingEnabled = false

        if flingDiedConn then
            flingDiedConn:Disconnect()
            flingDiedConn = nil
        end

        if rootPart then
            for _, v in pairs(rootPart:GetChildren()) do
                if v:IsA("BodyAngularVelocity") or v:IsA("BodyPosition") or v:IsA("BodyGyro") then
                    if v.Name:find("KTL_Fling") then
                        v:Destroy()
                    end
                end
            end

            rootPart.Velocity = Vector3.new(0, 0, 0)
            rootPart.RotVelocity = Vector3.new(0, 0, 0)
        end

        if character then
            local hum = character:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.PlatformStand = false
                hum.Sit = false
                hum:SetStateEnabled(Enum.HumanoidStateType.Physics, false)
