<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Morpion Infini Multijoueur</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --x: #00f5ff;
  --o: #ff2d78;
  --gold: #ffe066;
  --bg: #050510;
  --panel: rgba(255,255,255,0.035);
  --border: rgba(255,255,255,0.08);
  --border2: rgba(255,255,255,0.15);
}

body {
  background: var(--bg);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-family: 'Rajdhani', sans-serif;
  color: #fff;
  overflow: hidden;
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 50% at 20% 40%, rgba(0,245,255,0.04) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 80% 70%, rgba(255,45,120,0.05) 0%, transparent 60%);
  pointer-events: none;
}

.stars { position: fixed; inset: 0; pointer-events: none; overflow: hidden; }
.star {
  position: absolute; width: 2px; height: 2px; border-radius: 50%; background: #fff;
  animation: twinkle var(--d) ease-in-out infinite var(--delay);
}
@keyframes twinkle { 0%,100%{opacity:.1;transform:scale(1)} 50%{opacity:.7;transform:scale(1.4)} }

/* ── SCREENS ─────────────────────────────────── */
.screen {
  display: none;
  flex-direction: column;
  align-items: center;
  animation: fadeUp 0.4s ease forwards;
  width: min(420px, 94vw);
}
.screen.active { display: flex; }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── LOGO ────────────────────────────────────── */
.logo {
  font-family: 'Orbitron', monospace;
  font-size: clamp(1.6rem, 5vw, 2.6rem);
  font-weight: 900;
  letter-spacing: .3em;
  background: linear-gradient(135deg, var(--x), #a78bfa, var(--o));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 18px rgba(167,139,250,.5));
  animation: logoPulse 3s ease-in-out infinite;
  margin-bottom: .25em;
}
@keyframes logoPulse { 0%,100%{filter:drop-shadow(0 0 12px rgba(167,139,250,.4))} 50%{filter:drop-shadow(0 0 32px rgba(167,139,250,.8))} }

.sub {
  font-size: .8rem; letter-spacing: .4em; color: rgba(255,255,255,.3);
  text-transform: uppercase; margin-bottom: 2.5rem;
}

/* ── CARDS ───────────────────────────────────── */
.card {
  width: 100%;
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 1.6rem 1.8rem;
  margin-bottom: 1rem;
}

.card-title {
  font-family: 'Orbitron', monospace;
  font-size: .7rem;
  letter-spacing: .25em;
  color: rgba(255,255,255,.4);
  text-transform: uppercase;
  margin-bottom: 1.2rem;
}

/* ── INPUTS ──────────────────────────────────── */
.inp {
  width: 100%;
  background: rgba(0,0,0,.4);
  border: 1px solid var(--border2);
  border-radius: 10px;
  color: #fff;
  font-family: 'Orbitron', monospace;
  font-size: 1.4rem;
  font-weight: 700;
  letter-spacing: .3em;
  text-align: center;
  padding: .7rem 1rem;
  outline: none;
  transition: border-color .25s, box-shadow .25s;
  text-transform: uppercase;
}
.inp:focus { border-color: rgba(167,139,250,.6); box-shadow: 0 0 0 3px rgba(167,139,250,.12); }
.inp::placeholder { color: rgba(255,255,255,.2); }

/* ── BUTTONS ─────────────────────────────────── */
.btn {
  display: flex; align-items: center; justify-content: center; gap: .6rem;
  font-family: 'Orbitron', monospace;
  font-size: .65rem; letter-spacing: .2em; font-weight: 700;
  text-transform: uppercase;
  padding: .85rem 1.8rem;
  border-radius: 10px;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(255,255,255,.04);
  color: rgba(255,255,255,.7);
  cursor: pointer;
  transition: all .25s;
  width: 100%;
  position: relative; overflow: hidden;
}
.btn:hover { border-color: rgba(255,255,255,.25); color: #fff; transform: translateY(-2px); }
.btn:active { transform: translateY(0) scale(.98); }

.btn-primary {
  background: linear-gradient(135deg, rgba(0,245,255,.15), rgba(167,139,250,.15));
  border-color: rgba(0,245,255,.4);
  color: var(--x);
  text-shadow: 0 0 10px rgba(0,245,255,.5);
  box-shadow: 0 0 20px rgba(0,245,255,.1);
}
.btn-primary:hover { box-shadow: 0 0 30px rgba(0,245,255,.25); border-color: rgba(0,245,255,.7); }

.btn-secondary {
  background: linear-gradient(135deg, rgba(255,45,120,.12), rgba(167,139,250,.1));
  border-color: rgba(255,45,120,.35);
  color: var(--o);
  text-shadow: 0 0 10px rgba(255,45,120,.5);
  box-shadow: 0 0 20px rgba(255,45,120,.08);
}
.btn-secondary:hover { box-shadow: 0 0 30px rgba(255,45,120,.2); border-color: rgba(255,45,120,.6); }

.btn-sm {
  padding: .55rem 1rem;
  font-size: .6rem;
  width: auto;
}

.btn-row { display: flex; gap: .8rem; width: 100%; }

/* ── CODE DISPLAY ────────────────────────────── */
.code-box {
  width: 100%;
  background: rgba(0,0,0,.5);
  border: 1px solid rgba(0,245,255,.3);
  border-radius: 12px;
  padding: 1.2rem;
  text-align: center;
  margin-bottom: 1rem;
  box-shadow: 0 0 20px rgba(0,245,255,.08), inset 0 0 20px rgba(0,245,255,.03);
  position: relative;
}
.code-label { font-size: .7rem; letter-spacing: .25em; color: rgba(255,255,255,.35); margin-bottom: .4rem; }
.code-value {
  font-family: 'Orbitron', monospace;
  font-size: clamp(2rem, 8vw, 3rem);
  font-weight: 900;
  letter-spacing: .4em;
  color: var(--x);
  text-shadow: 0 0 20px var(--x), 0 0 40px rgba(0,245,255,.3);
}
.code-copy {
  position: absolute;
  top: .6rem; right: .6rem;
  font-size: .55rem;
}

/* ── WAITING DOTS ────────────────────────────── */
.waiting {
  display: flex; align-items: center; gap: .5rem;
  font-size: .8rem; letter-spacing: .1em; color: rgba(255,255,255,.4);
  margin: .8rem 0;
}
.dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,.3); animation: dotBounce 1.2s ease-in-out infinite; }
.dot:nth-child(2){ animation-delay:.2s }
.dot:nth-child(3){ animation-delay:.4s }
@keyframes dotBounce { 0%,80%,100%{transform:translateY(0);opacity:.3} 40%{transform:translateY(-6px);opacity:1} }

/* ── PLAYER BADGE ────────────────────────────── */
.player-badge {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .4rem 1rem;
  border-radius: 999px;
  font-family: 'Orbitron', monospace;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .2em;
  margin-bottom: 1.2rem;
}
.badge-x { background: rgba(0,245,255,.1); border: 1px solid rgba(0,245,255,.35); color: var(--x); text-shadow: 0 0 10px var(--x); }
.badge-o { background: rgba(255,45,120,.1); border: 1px solid rgba(255,45,120,.35); color: var(--o); text-shadow: 0 0 10px var(--o); }

/* ── GAME BOARD ──────────────────────────────── */
.turn-bar {
  width: 100%; display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 1rem; gap: .5rem;
}
.turn-label {
  font-size: .8rem; letter-spacing: .1em;
  color: rgba(255,255,255,.4); flex: 1; text-align: center;
  transition: all .3s;
}
.turn-label.active-x { color: var(--x); text-shadow: 0 0 12px var(--x); }
.turn-label.active-o { color: var(--o); text-shadow: 0 0 12px var(--o); }
.turn-arrow { font-size: .7rem; color: rgba(255,255,255,.2); }

.board-wrap {
  padding: 2px;
  border-radius: 20px;
  background: linear-gradient(135deg, rgba(0,245,255,.25), rgba(167,139,250,.18), rgba(255,45,120,.25));
  box-shadow: 0 0 40px rgba(0,245,255,.08), 0 0 80px rgba(255,45,120,.08);
  margin-bottom: 1rem;
}

.board {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4px;
  padding: 10px;
  background: rgba(5,5,20,.97);
  border-radius: 18px;
}

.cell {
  width: clamp(82px, 20vw, 120px);
  height: clamp(82px, 20vw, 120px);
  border-radius: 12px;
  background: var(--panel);
  border: 1px solid var(--border);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Orbitron', monospace;
  font-size: clamp(1.8rem, 7vw, 3rem);
  font-weight: 900;
  position: relative; overflow: hidden;
  transition: background .2s, border-color .2s, transform .15s;
  user-select: none;
}
.cell::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 50% 50%, rgba(255,255,255,.06), transparent 70%);
  opacity: 0; transition: opacity .2s;
}
.cell.playable:hover::before { opacity: 1; }
.cell.playable:hover { border-color: rgba(255,255,255,.2); transform: scale(1.04); background: rgba(255,255,255,.05); }
.cell:not(.playable) { cursor: default; }

.mark {
  position: relative; z-index: 1;
  opacity: 0; transform: scale(.3) rotate(-15deg);
}
.cell.placed .mark { animation: popIn .35s cubic-bezier(.175,.885,.32,1.275) forwards; }
@keyframes popIn {
  0%  { opacity:0; transform:scale(.3) rotate(-15deg); }
  60% { opacity:1; transform:scale(1.15) rotate(5deg); }
  100%{ opacity:1; transform:scale(1) rotate(0deg); }
}

.cell.x-cell .mark { color: var(--x); text-shadow: 0 0 20px var(--x), 0 0 40px var(--x); }
.cell.o-cell .mark { color: var(--o); text-shadow: 0 0 20px var(--o), 0 0 40px var(--o); }
.cell.x-cell { border-color: rgba(0,245,255,.25); background: rgba(0,245,255,.05); }
.cell.o-cell { border-color: rgba(255,45,120,.25); background: rgba(255,45,120,.05); }

.cell.winner { animation: winGlow .7s ease-in-out infinite alternate; }
.cell.x-cell.winner { border-color: rgba(0,245,255,.9); box-shadow: 0 0 25px rgba(0,245,255,.5), inset 0 0 20px rgba(0,245,255,.1); background: rgba(0,245,255,.12); }
.cell.o-cell.winner { border-color: rgba(255,45,120,.9); box-shadow: 0 0 25px rgba(255,45,120,.5), inset 0 0 20px rgba(255,45,120,.1); background: rgba(255,45,120,.12); }
@keyframes winGlow { 0%{transform:scale(1)} 100%{transform:scale(1.06)} }
.cell.dim { opacity: .3; }

/* ── STATUS ──────────────────────────────────── */
.game-status {
  font-size: .9rem; letter-spacing: .12em;
  text-align: center; min-height: 1.4rem;
  transition: all .3s;
  margin-bottom: .5rem;
}
.status-wait    { color: rgba(255,255,255,.35); }
.status-my-turn { color: var(--x); text-shadow: 0 0 12px var(--x); animation: turnPulse 1.5s ease-in-out infinite; }
.status-my-turn.o { color: var(--o); text-shadow: 0 0 12px var(--o); }
.status-their-turn { color: rgba(255,255,255,.35); }
.status-win  { color: var(--gold); text-shadow: 0 0 18px var(--gold); animation: winPulse .6s ease-in-out infinite; }
.status-lose { color: rgba(255,255,255,.35); }
.status-draw { color: rgba(255,255,255,.5); }
@keyframes turnPulse { 0%,100%{opacity:1} 50%{opacity:.6} }
@keyframes winPulse  { 0%,100%{opacity:1} 50%{opacity:.55} }

/* ── RESULT OVERLAY ──────────────────────────── */
.result-banner {
  display: none;
  width: 100%;
  background: rgba(0,0,0,.6);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 14px;
  padding: 1rem 1.4rem;
  text-align: center;
  margin-bottom: .8rem;
  backdrop-filter: blur(4px);
}
.result-banner.show { display: block; animation: fadeUp .4s ease; }
.result-title { font-family: 'Orbitron', monospace; font-size: 1rem; font-weight: 900; letter-spacing: .2em; margin-bottom: .2rem; }
.result-sub { font-size: .75rem; letter-spacing: .1em; color: rgba(255,255,255,.4); }

/* ── FLASH ───────────────────────────────────── */
.flash { position: fixed; inset: 0; pointer-events: none; opacity: 0; animation: flashAnim .5s ease-out forwards; }
.flash.x { background: radial-gradient(ellipse at center, rgba(0,245,255,.18), transparent 70%); }
.flash.o { background: radial-gradient(ellipse at center, rgba(255,45,120,.18), transparent 70%); }
@keyframes flashAnim { 0%{opacity:1} 100%{opacity:0} }

/* ── ERROR ───────────────────────────────────── */
.err { color: #ff6b6b; font-size: .8rem; letter-spacing: .08em; text-align: center; min-height: 1.2rem; margin-top: .5rem; }

/* ── MISC ────────────────────────────────────── */
.separator { width: 100%; height: 1px; background: var(--border); margin: .8rem 0; }
.hint { font-size: .75rem; letter-spacing: .08em; color: rgba(255,255,255,.3); text-align: center; line-height: 1.6; }
.pulse { animation: pulse 2s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:.5} 50%{opacity:1} }
</style>
</head>
<body>

<div class="stars" id="stars"></div>

<div class="screen active" id="screen-home">
  <div class="logo">INFINI</div>
  <p class="sub">3 pions max · Pas de match nul</p>

  <div class="card">
    <p class="card-title">Nouvelle partie</p>
    <button class="btn btn-primary" onclick="createGame()">
      <span style="font-size:1rem">⚡</span> Créer une partie
    </button>
  </div>

  <div class="card">
    <p class="card-title">Rejoindre une partie</p>
    <input class="inp" id="joinCode" placeholder="CODE" maxlength="6" spellcheck="false">
    <div class="err" id="joinErr"></div>
    <div style="margin-top:.8rem">
      <button class="btn btn-secondary" onclick="joinGame()">
        <span style="font-size:1rem">🎮</span> Rejoindre
      </button>
    </div>
  </div>

  <p class="hint">Quand vous posez un 4ème pion, le plus ancien non gagnant disparaît !</p>
</div>

<div class="screen" id="screen-waiting">
  <div class="logo">INFINI</div>
  <p class="sub" style="margin-bottom:1.5rem">En attente d'un adversaire</p>

  <div class="code-box">
    <p class="code-label">Code d'invitation</p>
    <div class="code-value" id="waitCode">——</div>
    <button class="btn btn-sm code-copy" onclick="copyCode()" id="copyBtn">copier</button>
  </div>

  <div class="waiting">
    <div class="dot"></div><div class="dot"></div><div class="dot"></div>
    <span>En attente de connexion</span>
  </div>

  <div style="margin-top:1.5rem; width:100%">
    <button class="btn btn-sm" onclick="goHome()" style="border-color:rgba(255,80,80,.3);color:rgba(255,80,80,.6)">
      Annuler
    </button>
  </div>
</div>

<div class="screen" id="screen-game">
  <div class="logo" style="font-size:clamp(1.2rem,3.5vw,1.8rem);margin-bottom:.1em">INFINI</div>

  <div id="playerBadge" class="player-badge badge-x">Vous jouez X</div>

  <div class="turn-bar">
    <div id="xTurn" class="turn-label">JOUEUR X</div>
    <div class="turn-arrow">⟷</div>
    <div id="oTurn" class="turn-label">JOUEUR O</div>
  </div>

  <div class="result-banner" id="resultBanner">
    <div class="result-title" id="resultTitle"></div>
    <div class="result-sub" id="resultSub"></div>
  </div>

  <div class="board-wrap">
    <div class="board" id="board">
      <div class="cell" data-i="0"><span class="mark"></span></div>
      <div class="cell" data-i="1"><span class="mark"></span></div>
      <div class="cell" data-i="2"><span class="mark"></span></div>
      <div class="cell" data-i="3"><span class="mark"></span></div>
      <div class="cell" data-i="4"><span class="mark"></span></div>
      <div class="cell" data-i="5"><span class="mark"></span></div>
      <div class="cell" data-i="6"><span class="mark"></span></div>
      <div class="cell" data-i="7"><span class="mark"></span></div>
      <div class="cell" data-i="8"><span class="mark"></span></div>
    </div>
  </div>

  <div class="game-status" id="gameStatus"></div>

  <div class="btn-row" style="margin-top:.5rem">
    <button class="btn btn-sm btn-primary" id="btnReplay" style="display:none" onclick="requestRematch()">Rejouer</button>
    <button class="btn btn-sm" onclick="goHome()" style="border-color:rgba(255,80,80,.25);color:rgba(255,80,80,.55);font-size:.55rem">Quitter</button>
  </div>

  <p class="hint" style="margin-top:.8rem" id="codeHint"></p>
</div>

<script>
const WINS = [[0,1,2],[3,4,5],[6,7,8],[0,3,6],[1,4,7],[2,5,8],[0,4,8],[2,4,6]];
const SESSION = Math.random().toString(36).slice(2, 10);
let currentCode = null;
let myRole = null;
let pollTimer = null;
let lastStateStr = null;
let gameOver = false;
let rematchVote = false;

/* ── STORAGE ── */
async function saveGame(code, state) {
  try { localStorage.setItem('mrpn:' + code, JSON.stringify(state)); } catch(e){ console.error(e); }
}
async function loadGame(code) {
  try {
    const r = localStorage.getItem('mrpn:' + code);
    return r ? JSON.parse(r) : null;
  } catch(e){ return null; }
}

/* ── HELPERS ── */
function genCode() {
  const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  return Array.from({length: 6}, () => chars[Math.floor(Math.random() * chars.length)]).join('');
}

function checkWin(board) {
  for (const c of WINS) {
    if (board[c[0]] && board[c[0]] === board[c[1]] && board[c[1]] === board[c[2]]) return c;
  }
  return null;
}

function show(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + id).classList.add('active');
}

function stopPoll() {
  if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
}

function flash(p) {
  const f = document.createElement('div');
  f.className = 'flash ' + p.toLowerCase();
  document.body.appendChild(f);
  f.addEventListener('animationend', () => f.remove());
}

function goHome() {
  stopPoll();
  currentCode = null; myRole = null; gameOver = false; rematchVote = false;
  document.getElementById('joinCode').value = '';
  document.getElementById('joinErr').textContent = '';
  show('home');
}

/* ── SYNC ── */
function syncGameState(state) {
  if (!state) return;
  const stateStr = JSON.stringify(state);
  if (stateStr === lastStateStr) return;
  lastStateStr = stateStr;

  if (state.status === 'playing' && document.getElementById('screen-waiting').classList.contains('active')) {
    stopPoll();
    enterGame(state);
    return;
  }

  if (document.getElementById('screen-game').classList.contains('active')) {
    if (gameOver && state.status === 'playing') {
      gameOver = false;
      rematchVote = false;
      document.getElementById('btnReplay').style.display = 'none';
      document.getElementById('btnReplay').textContent = 'Rejouer';
      document.getElementById('resultBanner').classList.remove('show');
    }
    renderBoard(state);
  }
}

/* ── GAME LOGIC ── */
async function createGame() {
  const code = genCode();
  currentCode = code;
  myRole = 'X';

  const state = {
    board: Array(9).fill(null),
    queueX: [],
    queueO: [],
    turn: 'X',
    status: 'waiting',
    winner: null,
    winCombo: null,
    xPlayer: SESSION,
    oPlayer: null,
    rematchX: false,
    rematchO: false,
  };

  await saveGame(code, state);
  document.getElementById('waitCode').textContent = code;
  show('waiting');
  startWaitPoll();
}

function startWaitPoll() {
  stopPoll();
  pollTimer = setInterval(async () => {
    const state = await loadGame(currentCode);
    if (state) syncGameState(state);
  }, 1000);
}

async function joinGame() {
  const code = document.getElementById('joinCode').value.trim().toUpperCase();
  const errEl = document.getElementById('joinErr');
  errEl.textContent = '';
  if (code.length < 4) return;

  const state = await loadGame(code);
  if (!state) { errEl.textContent = 'Partie introuvable'; return; }
  if (state.status !== 'waiting') { errEl.textContent = 'Déjà commencée'; return; }
  if (state.xPlayer === SESSION) return;

  currentCode = code;
  myRole = 'O';
  state.oPlayer = SESSION;
  state.status = 'playing';
  await saveGame(code, state);
  enterGame(state);
}

function enterGame(state) {
  gameOver = false;
  rematchVote = false;
  const badge = document.getElementById('playerBadge');
  badge.textContent = 'Vous jouez ' + myRole;
  badge.className = 'player-badge badge-' + myRole.toLowerCase();
  document.getElementById('codeHint').textContent = 'Code : ' + currentCode;
  renderBoard(state);
  show('game');
  startGamePoll();
}

function renderBoard(state) {
  const cells = document.querySelectorAll('.cell');

  cells.forEach((cell, i) => {
    const v = state.board[i];
    cell.className = 'cell';
    const mark = cell.querySelector('.mark');
    mark.textContent = v || '';

    if (v) {
      cell.classList.add(v.toLowerCase() + '-cell', 'placed');
    }
  });

  const win = state.winCombo;
  if (win) {
    win.forEach(idx => cells[idx].classList.add('winner'));
    cells.forEach((c, idx) => { if (!win.includes(idx)) c.classList.add('dim'); });
  }

  const isMine = (state.turn === myRole && !state.winner);
  cells.forEach(cell => {
    const i = +cell.dataset.i;
    if (isMine && !state.board[i]) {
      cell.classList.add('playable');
      cell.onclick = () => makeMove(i);
    } else cell.onclick = null;
  });

  updateTurnBar(state);
  updateStatus(state);

  if (state.status === 'finished' && !gameOver) {
    showResult(state);
    document.getElementById('btnReplay').style.display = 'flex';
  }
}

function updateTurnBar(state) {
  document.getElementById('xTurn').className = 'turn-label' + (state.turn === 'X' && !state.winner ? ' active-x' : '');
  document.getElementById('oTurn').className = 'turn-label' + (state.turn === 'O' && !state.winner ? ' active-o' : '');
}

function updateStatus(state) {
  const el = document.getElementById('gameStatus');
  if (state.status === 'finished') return;
  if (state.turn === myRole) {
    el.className = 'game-status status-my-turn' + (myRole === 'O' ? ' o' : '');
    el.textContent = '⚡ À toi de jouer !';
  } else {
    el.className = 'game-status status-their-turn';
    el.textContent = "L'adversaire réfléchit…";
  }
}

function showResult(state) {
  const banner = document.getElementById('resultBanner');
  banner.classList.add('show');
  document.getElementById('resultTitle').textContent = state.winner === myRole ? '🏆 VICTOIRE !' : '💀 DÉFAITE';
  document.getElementById('resultSub').textContent = state.winner === myRole ? 'Tu as été plus stratège !' : 'L\'adversaire a gagné...';
  if (state.winner === myRole) flash(myRole);
  gameOver = true;
}

/* ── MOVE LOGIC ── */
async function makeMove(i) {
  if (gameOver) return;
  const state = await loadGame(currentCode);
  if (!state || state.board[i] || state.turn !== myRole) return;

  const currentQueue = myRole === 'X' ? state.queueX : state.queueO;

  // 1. Si on a déjà 3 pions, vérifier s'ils forment une victoire avec le nouveau
  if (currentQueue.length === 3) {
    // Simuler le board avec le nouveau pion
    const tempBoard = [...state.board];
    tempBoard[i] = myRole;
    const wouldWin = checkWin(tempBoard);

    // Si les 3 pions actuels + le nouveau forment une victoire, on ne supprime rien
    if (!wouldWin) {
      // Sinon, vérifier si le plus ancien pion fait partie d'une victoire existante
      const oldestIdx = currentQueue[0];
      const isOldestInWinCombo = state.winCombo && state.winCombo.includes(oldestIdx);

      // Si le plus ancien pion ne fait pas partie d'une victoire, on le supprime
      if (!isOldestInWinCombo) {
        state.board[oldestIdx] = null;
        currentQueue.shift(); // Retire le plus ancien de la file
      }
    }
  }

  // 2. On place le nouveau pion
  state.board[i] = myRole;
  currentQueue.push(i);

  // 3. Vérifier victoire
  const win = checkWin(state.board);
  if (win) {
    state.winner = myRole;
    state.winCombo = win;
    state.status = 'finished';
  } else {
    state.turn = myRole === 'X' ? 'O' : 'X';
  }

  await saveGame(currentCode, state);
  syncGameState(state);
}

async function requestRematch() {
  if (rematchVote) return;
  rematchVote = true;
  document.getElementById('btnReplay').textContent = 'En attente…';
  const state = await loadGame(currentCode);
  if (myRole === 'X') state.rematchX = true; else state.rematchO = true;

  if (state.rematchX && state.rematchO) {
    const newState = {
      board: Array(9).fill(null),
      queueX: [], queueO: [],
      turn: 'X', status: 'playing',
      winner: null, winCombo: null,
      xPlayer: state.xPlayer, oPlayer: state.oPlayer,
      rematchX: false, rematchO: false,
    };
    await saveGame(currentCode, newState);
    syncGameState(newState);
  } else await saveGame(currentCode, state);
}

function startGamePoll() {
  stopPoll();
  pollTimer = setInterval(async () => {
    const state = await loadGame(currentCode);
    if (state) syncGameState(state);
  }, 800);
}

window.addEventListener('storage', (e) => {
  if (currentCode && e.key === 'mrpn:' + currentCode && e.newValue) syncGameState(JSON.parse(e.newValue));
});

document.addEventListener("visibilitychange", async () => {
  if (!document.hidden && currentCode) {
    const state = await loadGame(currentCode);
    if (state) syncGameState(state);
  }
});

function copyCode() {
  const code = document.getElementById('waitCode').textContent;
  navigator.clipboard.writeText(code).then(() => {
    document.getElementById('copyBtn').textContent = '✓';
    setTimeout(() => document.getElementById('copyBtn').textContent = 'copier', 2000);
  });
}

(function() {
  const c = document.getElementById('stars');
  for (let i = 0; i < 70; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    s.style.cssText = `left:${Math.random()*100}%;top:${Math.random()*100}%;--d:${2+Math.random()*4}s;--delay:${-Math.random()*4}s`;
    c.appendChild(s);
  }
})();
</script>
