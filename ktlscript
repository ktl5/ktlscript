-- Ajout des coins invisibles pour redimensionner
local resizeCorners = {"BottomRight"}
local resizeHandles = {}

for _, corner in ipairs(resizeCorners) do
    local handle = Instance.new("Frame")
    handle.Name = "ResizeHandle_" .. corner
    handle.Size = UDim2.new(0, 18, 0, 18)
    handle.BackgroundTransparency = 1
    handle.BorderSizePixel = 0
    handle.ZIndex = 10
    handle.Parent = MainPanel

    local cornerPos = {
        TopLeft = UDim2.new(0, 0, 0, 0),
        BottomRight = UDim2.new(1, -18, 1, -18)
    }
    handle.Position = cornerPos[corner]
    addCorner(handle, 3)

    local dragging = false
    local startPos, startSize

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            startPos = Vector2.new(Mouse.X, Mouse.Y)
            startSize = MainPanel.AbsoluteSize
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = Vector2.new(Mouse.X - startPos.X, Mouse.Y - startPos.Y)
            local newWidth, newHeight = startSize.X, startSize.Y

            if corner == "TopLeft" then
                newWidth = startSize.X - delta.X
                newHeight = startSize.Y - delta.Y
                MainPanel.Position = UDim2.new(0, MainPanel.Position.X.Offset + delta.X, 0, MainPanel.Position.Y.Offset + delta.Y)
            elseif corner == "BottomRight" then
                newWidth = startSize.X + delta.X
                newHeight = startSize.Y + delta.Y
            end

            -- Limiter la taille minimale
            newWidth = math.max(450, newWidth)
            newHeight = math.max(400, newHeight)

            MainPanel.Size = UDim2.new(0, newWidth, 0, newHeight)
            _G.UI_Width = newWidth
            _G.UI_Height = newHeight
        end
    end)
end

