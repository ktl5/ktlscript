UserInputService.InputBegan:Connect(function(i, gp)
    if gp or not _G.NB5_Running then
        return
    end
    if i.KeyCode == Enum.KeyCode.T then
        MainPanel.Visible = not MainPanel.Visible
        if MainPanel.Visible then
            TweenService:Create(MainPanel, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = UDim2.new(0, _G.UI_Width, 0, _G.UI_Height)}):Play()
        else
            TweenService:Create(MainPanel, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = UDim2.new(0, 0, 0, 0)}):Play()
        end
    end
    if i.KeyCode == Enum.KeyCode.G then
        _G.AimLock_Enabled = not _G.AimLock_Enabled
        setAimLock(_G.AimLock_Enabled)
    end
    if i.KeyCode == Enum.KeyCode.CapsLock then
        _G.CameraNoclip = not _G.CameraNoclip
        setCamNoclip(_G.CameraNoclip)
    end
    if i.KeyCode == Enum.KeyCode.V then
        _G.FlyEnabled = not _G.FlyEnabled
        setFly(_G.FlyEnabled)
