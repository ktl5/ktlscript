local function ApplyCollisionSlide(hrp, velocity)
    if velocity.Magnitude < 0.5 then
        return velocity
    end
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {LocalPlayer.Character}
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local origin = hrp.Position
    local velDir = velocity.Unit
    local hs = hrp.Size * 0.5
    local offsets = {Vector3.zero, Vector3.new(hs.X, hs.Y, 0), Vector3.new(-hs.X, hs.Y, 0), Vector3.new(hs.X, -hs.Y, 0), Vector3.new(-hs.X, -hs.Y, 0)}
    local hitNormals = {}
    for _, off in ipairs(offsets) do
        local r = workspace:Raycast(origin + off, velDir * 2.8, rp)
        if r then
            table.insert(hitNormals, r.Normal)
        end
    end
    if #hitNormals == 0 then
        return velocity
    end
    local avg = Vector3.zero
    for _, n in ipairs(hitNormals) do
        avg = avg + n
    end
    avg = (avg / #hitNormals).Unit
    local pen = velocity:Dot(avg)
    if pen < 0 then
        return (velocity - avg * pen) * 0.85
    end
    return velocity
end

local function GetClosestPlayer()
    local closest, shortest = nil, _G.AimLock_Radius
    local ml = UserInputService:GetMouseLocation()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - ml).Magnitude
                if dist < shortest then
                    closest = p
                    shortest = dist
                end
            end
        end
    end
    return closest
end

