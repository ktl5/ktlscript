local function refreshConfigList()
    for _, c in ipairs(configListScroll:GetChildren()) do
        if c:IsA("Frame") or c:IsA("TextLabel") then
            c:Destroy()
        end
    end
    local configs = listConfigs()
    local autoload = getAutoload()
    if #configs == 0 then
        local e = Instance.new("TextLabel")
        e.Size = UDim2.new(1, 0, 0, 30)
        e.BackgroundTransparency = 1
        e.Text = "Aucun config sauvegardé"
        e.TextColor3 = Color3.fromRGB(100, 100, 110)
        e.Font = Enum.Font.Gotham
        e.TextSize = 11
        e.TextXAlignment = Enum.TextXAlignment.Center
        e.Parent = configListScroll
        return
    end
    for _, name in ipairs(configs) do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, 0, 0, 34)
        row.BackgroundColor3 = Color3.fromRGB(26, 26, 28)
        row.BackgroundTransparency = 0.3
        row.BorderSizePixel = 0
        row.Parent = configListScroll
        addCorner(row, 12)

        local nl = Instance.new("TextLabel")
        nl.Size = UDim2.new(1, -120, 1, 0)
        nl.Position = UDim2.new(0, 10, 0, 0)
        nl.BackgroundTransparency = 1
        nl.Text = (name == autoload and "★ " or "") .. name
        nl.TextColor3 = name == autoload and Color3.fromRGB(255, 214, 10) or Color3.fromRGB(235, 235, 240)
        nl.Font = Enum.Font.Gotham
        nl.TextSize = 12
        nl.TextXAlignment = Enum.TextXAlignment.Left
        nl.Parent = row

        local function mkBtn(label, posX, w, bgColor, cb)
            local b = Instance.new("TextButton")
            b.Size = UDim2.new(0, w, 0, 22)
            b.Position = UDim2.new(1, posX, 0.5, -11)
            b.BackgroundColor3 = bgColor
            b.Text = label
            b.TextColor3 = Color3.new(1, 1, 1)
            b.Font = Enum.Font.GothamBold
            b.TextSize = 10
            b.BorderSizePixel = 0
            b.Parent = row
            addCorner(b, 8)
            b.MouseButton1Click:Connect(cb)
            return b
        end

        mkBtn("Load", -118, 38, Color3.fromRGB(10, 132, 255), function()
            loadConfig(name)
            -- Appliquer la taille sauvegardée
            MainPanel.Size = UDim2.new(0, _G.UI_Width, 0, _G.UI_Height)
            MainPanel.Position = UDim2.new(0.5, -_G.UI_Width/2, 0.5, -_G.UI_Height/2)
            notify("Config chargé", name, Color3.fromRGB(10, 132, 255))
        end)
        mkBtn("★", -74, 24, name == autoload and Color3.fromRGB(255, 159, 10) or Color3.fromRGB(40, 40, 42), function()
            if getAutoload() == name then
                setAutoload("")
            else
                setAutoload(name)
            end
            refreshConfigList()
        end)
        mkBtn("🗑", -44, 24, Color3.fromRGB(255, 69, 58), function()
            if getAutoload() == name then
                setAutoload("")
            end
            deleteConfig(name)
            notify("Config supprimé", name, Color3.fromRGB(255, 69, 58))
            refreshConfigList()
        end)
    end
end

