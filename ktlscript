            local hrp = LocalPlayer.Character.HumanoidRootPart
            local vel = hrp.Velocity
            if vel.Magnitude > 75 and not isDashing then
                isDashing = true
                local dir = vel.Unit
                local bv = Instance.new("BodyVelocity")
                bv.MaxForce = Vector3.new(100000,0,100000)
                bv.Velocity = dir * (vel.Magnitude * 1.5)
                bv.Parent = hrp
                task.wait(_G.DashBoost_Multiplier * 0.05)
                if bv and bv.Parent then
                    for i=1,5 do bv.Velocity=bv.Velocity*0.6 task.wait(0.02) end
                    bv:Destroy()
                end
                task.wait(0.3)
                isDashing = false
            end
        end
    end)

    -- =============================================
    --    RENDER STEPPED — FLY SMOOTH + COLLISIONS
    -- =============================================
    RunService.RenderStepped:Connect(function(deltaTime)
        if not _G.KTL5_Running then return end

        if _G.AimLock_Enabled and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            local t = GetClosestPlayer()
            if t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") and mousemoverel then
                local pos = Camera:WorldToViewportPoint(t.Character.HumanoidRootPart.Position)
                local ml = UIS:GetMouseLocation()
                mousemoverel((pos.X-ml.X)*_G.AimLock_Smoothness, (pos.Y-ml.Y)*_G.AimLock_Smoothness)
            end
        end
        FOVCircle.Position = UIS:GetMouseLocation()

        -- =============================================
        --   FLY LOGIC — SMOOTH (code précédent)
        --   + COLLISION SLIDE sur murs et sol
        -- =============================================
        if _G.FlyEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = LocalPlayer.Character.HumanoidRootPart
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")

            if not hrp:FindFirstChild("KTL5_FlyBV") then
                if hum then hum.PlatformStand = true end

                flyBodyVelocity = Instance.new("BodyVelocity")
                flyBodyVelocity.Name = "KTL5_FlyBV"
                flyBodyVelocity.MaxForce = Vector3.new(100000,100000,100000)
                flyBodyVelocity.Velocity = Vector3.zero
                flyBodyVelocity.Parent = hrp

                flyBodyGyro = Instance.new("BodyGyro")
                flyBodyGyro.Name = "KTL5_FlyBG"
                flyBodyGyro.MaxTorque = Vector3.new(100000,100000,100000)
                flyBodyGyro.P = 2500
                flyBodyGyro.D = 400
                flyBodyGyro.CFrame = Camera.CFrame
                flyBodyGyro.Parent = hrp

                smoothedLookVector  = Camera.CFrame.LookVector
                smoothedRightVector = Camera.CFrame.RightVector
                currentFlyVelocity  = Vector3.zero
            end

            if flyBodyVelocity and flyBodyGyro and flyBodyGyro.Parent == hrp then
                if hum then hum.PlatformStand = true end

                -- Lissage direction caméra (évite saccades souris)
                local cf = math.clamp(deltaTime * 18, 0, 1)
                smoothedLookVector  = smoothedLookVector:Lerp(Camera.CFrame.LookVector,  cf)
                smoothedRightVector = smoothedRightVector:Lerp(Camera.CFrame.RightVector, cf)
                flyBodyGyro.CFrame  = CFrame.new(Vector3.zero, smoothedLookVector)

                -- Direction souhaitée
                local moveDir = Vector3.zero
                if UIS:IsKeyDown(Enum.KeyCode.W)            then moveDir = moveDir + smoothedLookVector end
                if UIS:IsKeyDown(Enum.KeyCode.S)            then moveDir = moveDir - smoothedLookVector end
                if UIS:IsKeyDown(Enum.KeyCode.A)            then moveDir = moveDir - smoothedRightVector end
                if UIS:IsKeyDown(Enum.KeyCode.D)            then moveDir = moveDir + smoothedRightVector end
                if UIS:IsKeyDown(Enum.KeyCode.Space)        then moveDir = moveDir + Vector3.new(0,1,0) end
                if UIS:IsKeyDown(Enum.KeyCode.LeftControl)  then moveDir = moveDir - Vector3.new(0,1,0) end

                local targetVelocity = moveDir.Magnitude > 0
                    and moveDir.Unit * _G.FlySpeed
                    or Vector3.zero

                -- Lerp asymétrique (accél rapide, décél glissante)
                local isMoving  = moveDir.Magnitude > 0
                local lerpSpeed = isMoving and (deltaTime * 7) or (deltaTime * 3)
                currentFlyVelocity = currentFlyVelocity:Lerp(targetVelocity, math.clamp(lerpSpeed, 0, 1))

                -- ─────────────────────────────────────────
                --   COLLISION SLIDE
                --   On passe la vélocité dans le filtre
                --   de collision → elle est redirigée le
                --   long des surfaces au lieu de bloquer
                -- ─────────────────────────────────────────
                local safeVelocity = ApplyCollisionSlide(hrp, currentFlyVelocity)

                -- Si la collision a changé la vélocité, on
                -- met à jour currentFlyVelocity pour ne pas
                -- "accumuler" de la vitesse dans le mur
                if safeVelocity ~= currentFlyVelocity then
                    currentFlyVelocity = safeVelocity
                end

                flyBodyVelocity.Velocity = safeVelocity
            end
        end

        -- TP Walk
        if _G.TPWalkEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.MoveDirection.Magnitude > 0 then
                LocalPlayer.Character.HumanoidRootPart.CFrame += hum.MoveDirection * _G.TPWalkSpeed * 0.1
            end
        end
    end)

