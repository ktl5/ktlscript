-- ==================== SAVE SYSTEM ====================
local SAVE_FOLDER = "nb5_hub"
local CONFIG_FOLDER = SAVE_FOLDER .. "/configs"
local AUTOLOAD_FILE = SAVE_FOLDER .. "/autoload.txt"

pcall(function()
    if not isfolder(SAVE_FOLDER) then
        makefolder(SAVE_FOLDER)
    end
    if not isfolder(CONFIG_FOLDER) then
        makefolder(CONFIG_FOLDER)
    end
end)

local SaveRegistry = {}
local function registerSaveable(key, getter, setter)
    table.insert(SaveRegistry, {key = key, getValue = getter, setValue = setter})
end

local function getConfigPath(n)
    return CONFIG_FOLDER .. "/" .. n .. ".json"
end

local function saveConfig(name)
    local data = {}
    for _, e in ipairs(SaveRegistry) do
        data[e.key] = e.getValue()
    end
    -- Sauvegarder la taille de l'interface
    data.UI_Width = _G.UI_Width
    data.UI_Height = _G.UI_Height
    local ok, enc = pcall(HttpService.JSONEncode, HttpService, data)
    if ok then
        pcall(writefile, getConfigPath(name), enc)
        return true
    end
    return false
end

local function loadConfig(name)
    local ok, content = pcall(readfile, getConfigPath(name))
    if not ok or not content or content == "" then
        return false
    end
    local ok2, data = pcall(HttpService.JSONDecode, HttpService, content)
    if not ok2 or type(data) ~= "table" then
        return false
    end
    for _, e in ipairs(SaveRegistry) do
        if data[e.key] ~= nil then
            pcall(e.setValue, data[e.key])
        end
    end
    -- Charger la taille de l'interface
    if data.UI_Width and data.UI_Height then
        _G.UI_Width = data.UI_Width
        _G.UI_Height = data.UI_Height
    end
    return true
end

local function listConfigs()
    local list = {}
    pcall(function()
        for _, f in ipairs(listfiles(CONFIG_FOLDER)) do
            local n = f:match("([^/\\]+)%.json$")
            if n then
                table.insert(list, n)
            end
        end
    end)
    return list
end

local function setAutoload(n)
    pcall(writefile, AUTOLOAD_FILE, n or "")
end

local function getAutoload()
    local ok, c = pcall(readfile, AUTOLOAD_FILE)
    return (ok and c and c ~= "") and c or nil
end

local function deleteConfig(n)
    pcall(delfile, getConfigPath(n))
end

