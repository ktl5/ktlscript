            lbl.BackgroundTransparency = 1 lbl.Size = UDim2.new(1,0,1,0)
            lbl.Text = player.Name lbl.TextColor3 = Color3.new(1,1,1)
            lbl.TextStrokeTransparency = 0 lbl.Font = Enum.Font.SourceSansBold lbl.TextSize = 14
        end
    end
end

