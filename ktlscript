UIS.InputBegan:Connect(function(i, gp)
    if gp or not _G.KTL5_Running then return end
    if i.KeyCode == Enum.KeyCode.T then MainFrame.Visible = not MainFrame.Visible end
    if i.KeyCode == Enum.KeyCode.G then _G.AimLock_Enabled = not _G.AimLock_Enabled setAimLock(_G.AimLock_Enabled) end
    if i.KeyCode == Enum.KeyCode.CapsLock then _G.CameraNoclip = not _G.CameraNoclip setCamNoclip(_G.CameraNoclip) end
    if i.KeyCode == Enum.KeyCode.V then
        _G.FlyEnabled = not _G.FlyEnabled
        setFly(_G.FlyEnabled)
        if not _G.FlyEnabled then CleanUpFly() end
    end
    if _G.ClickTP_Enabled and i.UserInputType == Enum.UserInputType.MouseButton1 and UIS:IsKeyDown(Enum.KeyCode.LeftControl) then
        if LocalPlayer.Character then
            LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(Mouse.Hit.p + Vector3.new(0, 3, 0))
        end
    end
end)

