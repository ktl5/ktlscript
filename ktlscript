local function refreshConfigList()
    if not configListScroll then return end
    for _, c in ipairs(configListScroll:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end

    local configs = listConfigs()
    local autoload = getAutoload()

    if #configs == 0 then
        itemOrder += 1
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 30)
        empty.BackgroundTransparency = 1
        empty.Text = "Aucun config sauvegardé"
        empty.TextColor3 = Color3.fromRGB(60, 90, 130)
        empty.Font = Enum.Font.Gotham
        empty.TextSize = 11
        empty.Parent = configListScroll
        return
    end

    for _, name in ipairs(configs) do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, 0, 0, 36)
        row.BackgroundColor3 = Color3.fromRGB(14, 20, 38)
        row.BorderSizePixel = 0
        row.Parent = configListScroll
        addCorner(row, 7)
        if name == autoload then
            addStroke(row, Color3.fromRGB(0, 200, 100), 1.2)
        else
            addStroke(row, Color3.fromRGB(25, 45, 80), 1)
        end

        -- Icône autoload
        local autoIcon = Instance.new("TextLabel")
        autoIcon.Size = UDim2.new(0, 20, 1, 0)
        autoIcon.Position = UDim2.new(0, 6, 0, 0)
        autoIcon.BackgroundTransparency = 1
        autoIcon.Text = name == autoload and "★" or "☆"
        autoIcon.TextColor3 = name == autoload and Color3.fromRGB(255, 200, 0) or Color3.fromRGB(60, 90, 130)
        autoIcon.Font = Enum.Font.GothamBold
        autoIcon.TextSize = 14
        autoIcon.Parent = row

        -- Nom du config
        local nameLbl = Instance.new("TextLabel")
        nameLbl.Size = UDim2.new(1, -130, 1, 0)
        nameLbl.Position = UDim2.new(0, 28, 0, 0)
        nameLbl.BackgroundTransparency = 1
        nameLbl.Text = name
        nameLbl.TextColor3 = Color3.fromRGB(180, 210, 255)
        nameLbl.Font = Enum.Font.GothamBold
        nameLbl.TextSize = 12
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        nameLbl.Parent = row

        -- Bouton Load
        local loadBtn = Instance.new("TextButton")
        loadBtn.Size = UDim2.new(0, 44, 0, 24)
        loadBtn.Position = UDim2.new(1, -122, 0.5, -12)
        loadBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
        loadBtn.Text = "Load"
        loadBtn.TextColor3 = Color3.new(1,1,1)
        loadBtn.Font = Enum.Font.GothamBold
        loadBtn.TextSize = 11
        loadBtn.BorderSizePixel = 0
        loadBtn.Parent = row
        addCorner(loadBtn, 6)
        loadBtn.MouseButton1Click:Connect(function()
            loadConfig(name)
            notify("Config loaded", name, Color3.fromRGB(0, 160, 255))
        end)
        loadBtn.MouseEnter:Connect(function() tw(loadBtn, {BackgroundColor3 = Color3.fromRGB(0, 140, 255)}, 0.1) end)
        loadBtn.MouseLeave:Connect(function() tw(loadBtn, {BackgroundColor3 = Color3.fromRGB(0, 100, 200)}, 0.1) end)

        -- Bouton Autoload (★)
        local alBtn = Instance.new("TextButton")
        alBtn.Size = UDim2.new(0, 30, 0, 24)
        alBtn.Position = UDim2.new(1, -74, 0.5, -12)
        alBtn.BackgroundColor3 = name == autoload and Color3.fromRGB(140, 100, 0) or Color3.fromRGB(30, 40, 70)
        alBtn.Text = "★"
        alBtn.TextColor3 = name == autoload and Color3.fromRGB(255, 200, 0) or Color3.fromRGB(100, 130, 180)
        alBtn.Font = Enum.Font.GothamBold
        alBtn.TextSize = 13
        alBtn.BorderSizePixel = 0
        alBtn.Parent = row
        addCorner(alBtn, 6)
        alBtn.MouseButton1Click:Connect(function()
            if getAutoload() == name then
                setAutoload("")
                notify("Autoload retiré", name, Color3.fromRGB(200, 100, 0))
            else
                setAutoload(name)
                notify("Autoload défini", name .. " se chargera au prochain lancement", Color3.fromRGB(255, 200, 0))
            end
            refreshConfigList()
        end)
        alBtn.MouseEnter:Connect(function() tw(alBtn, {BackgroundColor3 = Color3.fromRGB(100, 70, 0)}, 0.1) end)
        alBtn.MouseLeave:Connect(function()
            tw(alBtn, {BackgroundColor3 = getAutoload() == name and Color3.fromRGB(140, 100, 0) or Color3.fromRGB(30, 40, 70)}, 0.1)
        end)

        -- Bouton Delete
        local delBtn = Instance.new("TextButton")
        delBtn.Size = UDim2.new(0, 28, 0, 24)
        delBtn.Position = UDim2.new(1, -38, 0.5, -12)
        delBtn.BackgroundColor3 = Color3.fromRGB(100, 20, 30)
        delBtn.Text = "🗑"
        delBtn.TextColor3 = Color3.new(1,1,1)
        delBtn.Font = Enum.Font.GothamBold
        delBtn.TextSize = 12
        delBtn.BorderSizePixel = 0
        delBtn.Parent = row
        addCorner(delBtn, 6)
        delBtn.MouseButton1Click:Connect(function()
            if getAutoload() == name then setAutoload("") end
            deleteConfig(name)
            notify("Config supprimé", name, Color3.fromRGB(220, 60, 80))
            refreshConfigList()
        end)
        delBtn.MouseEnter:Connect(function() tw(delBtn, {BackgroundColor3 = Color3.fromRGB(180, 30, 50)}, 0.1) end)
        delBtn.MouseLeave:Connect(function() tw(delBtn, {BackgroundColor3 = Color3.fromRGB(100, 20, 30)}, 0.1) end)
    end
end

