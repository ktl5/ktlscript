local SAVE_FOLDER   = "ktl5_hub"
local CONFIG_FOLDER = SAVE_FOLDER .. "/configs"
local AUTOLOAD_FILE = SAVE_FOLDER .. "/autoload.txt"

-- Crée les dossiers si inexistants
pcall(function()
    if not isfolder(SAVE_FOLDER)   then makefolder(SAVE_FOLDER)   end
    if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end
end)

-- Registre centralisé de tous les éléments sauvegardables
local SaveRegistry = {}

local function registerSaveable(key, getter, setter)
    table.insert(SaveRegistry, { key = key, getValue = getter, setValue = setter })
end

local function getConfigPath(name)
    return CONFIG_FOLDER .. "/" .. name .. ".json"
end

local function saveConfig(name)
    local data = {}
    for _, entry in ipairs(SaveRegistry) do
        data[entry.key] = entry.getValue()
    end
    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if ok then
        pcall(writefile, getConfigPath(name), encoded)
        return true
    end
    return false
end

local function loadConfig(name)
    local path = getConfigPath(name)
    local ok, content = pcall(readfile, path)
    if not ok or not content or content == "" then return false end
    local ok2, data = pcall(HttpService.JSONDecode, HttpService, content)
    if not ok2 or type(data) ~= "table" then return false end
    for _, entry in ipairs(SaveRegistry) do
        if data[entry.key] ~= nil then
            pcall(entry.setValue, data[entry.key])
        end
    end
    return true
end

local function listConfigs()
    local list = {}
    pcall(function()
        for _, file in ipairs(listfiles(CONFIG_FOLDER)) do
            local name = file:match("([^/\\]+)%.json$")
            if name then table.insert(list, name) end
        end
    end)
    return list
end

local function setAutoload(name)
    pcall(writefile, AUTOLOAD_FILE, name or "")
end

local function getAutoload()
    local ok, content = pcall(readfile, AUTOLOAD_FILE)
    return (ok and content and content ~= "") and content or nil
end

local function deleteConfig(name)
    pcall(delfile, getConfigPath(name))
end

