local function createSlider(tabName, label, min, max, default, rounding, callback, saveKey)
    itemOrder = itemOrder + 1
    local value = default or min
    rounding = rounding or 0

    local group = Instance.new("Frame")
    group.Size = UDim2.new(1, 0, 0, 54)
    group.BackgroundColor3 = Color3.fromRGB(26, 26, 28)
    group.BackgroundTransparency = 0.3
    group.BorderSizePixel = 0
    group.LayoutOrder = itemOrder
    group.Parent = tabFrames[tabName]
    addCorner(group, 18)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.65, 0, 0, 20)
    lbl.Position = UDim2.new(0, 10, 0, 6)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(235, 235, 240)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 2
    lbl.Parent = group

    local valLbl = Instance.new("TextLabel")
    valLbl.Size = UDim2.new(0.3, -10, 0, 20)
    valLbl.Position = UDim2.new(0.7, 0, 0, 6)
    valLbl.BackgroundTransparency = 1
    valLbl.Text = tostring(rounding > 0 and math.round(value * 10 ^ rounding) / 10 ^ rounding or math.round(value))
    valLbl.TextColor3 = Color3.fromRGB(10, 132, 255)
    valLbl.Font = Enum.Font.GothamBold
    valLbl.TextSize = 12
    valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.ZIndex = 2
    valLbl.Parent = group

    local trackBg = Instance.new("Frame")
    trackBg.Size = UDim2.new(1, -20, 0, 4)
    trackBg.Position = UDim2.new(0, 10, 0, 38)
    trackBg.BackgroundColor3 = Color3.fromRGB(50, 50, 52)
    trackBg.BackgroundTransparency = 0.3
    trackBg.BorderSizePixel = 0
    trackBg.ZIndex = 2
    trackBg.Parent = group
    addCorner(trackBg, 2)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(10, 132, 255)
    fill.BorderSizePixel = 0
    fill.ZIndex = 3
    fill.Parent = trackBg
    addCorner(fill, 2)

    local thumb = Instance.new("Frame")
    thumb.Size = UDim2.new(0, 12, 0, 12)
    thumb.Position = UDim2.new((value - min) / (max - min), -6, 0.5, -6)
    thumb.BackgroundColor3 = Color3.new(1, 1, 1)
    thumb.BorderSizePixel = 0
    thumb.ZIndex = 4
    thumb.Parent = trackBg
    addCorner(thumb, 6)

    local dragging = false
    local sliderBtn = Instance.new("TextButton")
    sliderBtn.Size = UDim2.new(1, 0, 0, 28)
    sliderBtn.Position = UDim2.new(0, 0, 0.5, -14)
    sliderBtn.BackgroundTransparency = 1
    sliderBtn.Text = ""
    sliderBtn.ZIndex = 5
    sliderBtn.Parent = trackBg

    local function applyValue(v)
        value = v
        local pct = clamp((value - min) / (max - min), 0, 1)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        thumb.Position = UDim2.new(pct, -6, 0.5, -6)
        valLbl.Text = tostring(value)
        if callback then
            callback(value)
        end
    end

    local function updateSlider(inputX)
        local pct = clamp((inputX - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
        local raw = min + pct * (max - min)
        raw = rounding == 0 and math.round(raw) or math.round(raw * 10 ^ rounding) / 10 ^ rounding
        applyValue(raw)
    end

    sliderBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateSlider(inp.Position.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(inp.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    if saveKey then
        registerSaveable(saveKey, function()
            return value
        end, function(v)
            local n = tonumber(v)
            if n then
                applyValue(clamp(n, min, max))
            end
        end)
    end
end

