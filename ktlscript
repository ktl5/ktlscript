local flyBodyVelocity, flyBodyGyro
local currentFlyVelocity  = Vector3.zero
local smoothedLookVector  = Vector3.new(0, 0, -1)
local smoothedRightVector = Vector3.new(1, 0, 0)
local COLLISION_PROBE_DIST = 2.8
local SLIDE_DAMPING = 0.85

local function CleanUpFly()
    currentFlyVelocity  = Vector3.zero
    smoothedLookVector  = Vector3.new(0, 0, -1)
    smoothedRightVector = Vector3.new(1, 0, 0)
    if flyBodyVelocity then flyBodyVelocity:Destroy() flyBodyVelocity = nil end
    if flyBodyGyro     then flyBodyGyro:Destroy()     flyBodyGyro     = nil end
    if LocalPlayer.Character then
        local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local bv = hrp:FindFirstChild("KTL5_FlyBV") if bv then bv:Destroy() end
            local bg = hrp:FindFirstChild("KTL5_FlyBG") if bg then bg:Destroy() end
        end
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand = false end
    end
end

local function ApplyCollisionSlide(hrp, velocity)
    if velocity.Magnitude < 0.5 then return velocity end
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = { LocalPlayer.Character }
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    local origin   = hrp.Position
    local velDir   = velocity.Unit
    local halfSize = hrp.Size * 0.5
    local offsets  = {
        Vector3.zero,
        Vector3.new( halfSize.X,  halfSize.Y, 0),
        Vector3.new(-halfSize.X,  halfSize.Y, 0),
        Vector3.new( halfSize.X, -halfSize.Y, 0),
        Vector3.new(-halfSize.X, -halfSize.Y, 0),
    }
    local hitNormals = {}
    for _, offset in ipairs(offsets) do
        local result = workspace:Raycast(origin + offset, velDir * COLLISION_PROBE_DIST, rayParams)
        if result then table.insert(hitNormals, result.Normal) end
    end
    if #hitNormals == 0 then return velocity end
    local avgNormal = Vector3.zero
    for _, n in ipairs(hitNormals) do avgNormal = avgNormal + n end
    avgNormal = (avgNormal / #hitNormals).Unit
    local penetration = velocity:Dot(avgNormal)
    if penetration < 0 then
        return (velocity - avgNormal * penetration) * SLIDE_DAMPING
    end
    return velocity
end

local function GetClosestPlayer()
    local closestPlayer, shortestDistance = nil, _G.AimLock_Radius
    local mouseLoc = UIS:GetMouseLocation()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character
            and player.Character:FindFirstChild("HumanoidRootPart")
            and player.Character:FindFirstChild("Humanoid")
            and player.Character.Humanoid.Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - mouseLoc).Magnitude
                if dist < shortestDistance then closestPlayer = player shortestDistance = dist end
            end
        end
    end
    return closestPlayer
end

local function CreateNameTag(player)
    if player.Character and not player.Character:FindFirstChild("KTL5_NameTag") then
        local head = player.Character:WaitForChild("Head", 5)
        if head then
            local bb = Instance.new("BillboardGui", player.Character)
            bb.Name = "KTL5_NameTag" bb.Adornee = head
            bb.Size = UDim2.new(0,100,0,50) bb.StudsOffset = Vector3.new(0,2,0) bb.AlwaysOnTop = true
