local isDashing = false
RunService.Stepped:Connect(function()
    if not _G.NB5_Running then
        return
    end
    if _G.Noclip and LocalPlayer.Character then
        for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
            if v:IsA("BasePart") and v.CanCollide then
                v.CanCollide = false
            end
        end
    end
    LocalPlayer.DevCameraOcclusionMode = _G.CameraNoclip and Enum.DevCameraOcclusionMode.Invisicam or Enum.DevCameraOcclusionMode.Zoom

    if _G.DashBoost_Enabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        local vel = hrp.Velocity
        if vel.Magnitude > 75 and not isDashing then
            isDashing = true
            local dir = vel.Unit
            local bv = Instance.new("BodyVelocity")
            bv.MaxForce = Vector3.new(100000, 0, 100000)
            bv.Velocity = dir * (vel.Magnitude * 1.5)
            bv.Parent = hrp
            task.wait(_G.DashBoost_Multiplier * 0.05)
            if bv and bv.Parent then
                for i = 1, 5 do
                    bv.Velocity = bv.Velocity * 0.6
                    task.wait(0.02)
                end
                bv:Destroy()
            end
            task.wait(0.3)
            isDashing = false
        end
    end
end)

RunService.RenderStepped:Connect(function(dt)
    if not _G.NB5_Running then
        return
    end
    Camera.FieldOfView = _G.FOV

    if _G.AimLock_Enabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local t = GetClosestPlayer()
        if t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") and mousemoverel then
            local pos = Camera:WorldToViewportPoint(t.Character.HumanoidRootPart.Position)
            local ml = UserInputService:GetMouseLocation()
            mousemoverel((pos.X - ml.X) * _G.AimLock_Smoothness, (pos.Y - ml.Y) * _G.AimLock_Smoothness)
        end
    end
    FOVCircle.Position = UserInputService:GetMouseLocation()

    if _G.FlyEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if not hrp:FindFirstChild("NB5_FlyBV") then
            if hum then
                hum.PlatformStand = true
            end
            flyBodyVelocity = Instance.new("BodyVelocity")
            flyBodyVelocity.Name = "NB5_FlyBV"
            flyBodyVelocity.MaxForce = Vector3.new(100000, 100000, 100000)
            flyBodyVelocity.Velocity = Vector3.zero
            flyBodyVelocity.Parent = hrp
            flyBodyGyro = Instance.new("BodyGyro")
            flyBodyGyro.Name = "NB5_FlyBG"
            flyBodyGyro.MaxTorque = Vector3.new(100000, 100000, 100000)
            flyBodyGyro.P = 2500
            flyBodyGyro.D = 400
            flyBodyGyro.CFrame = Camera.CFrame
            flyBodyGyro.Parent = hrp
            smoothedLookVector = Camera.CFrame.LookVector
            smoothedRightVector = Camera.CFrame.RightVector
            currentFlyVelocity = Vector3.zero
        end
        if flyBodyVelocity and flyBodyGyro and flyBodyGyro.Parent == hrp then
            if hum then
                hum.PlatformStand = true
            end
            local cf = math.clamp(dt * 18, 0, 1)
            smoothedLookVector = smoothedLookVector:Lerp(Camera.CFrame.LookVector, cf)
            smoothedRightVector = smoothedRightVector:Lerp(Camera.CFrame.RightVector, cf)
            flyBodyGyro.CFrame = CFrame.new(Vector3.zero, smoothedLookVector)
            local moveDir = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                moveDir = moveDir + smoothedLookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                moveDir = moveDir - smoothedLookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                moveDir = moveDir - smoothedRightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                moveDir = moveDir + smoothedRightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                moveDir = moveDir + Vector3.new(0, 1, 0)
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
                moveDir = moveDir - Vector3.new(0, 1, 0)
            end
            local targetVel = moveDir.Magnitude > 0 and moveDir.Unit * _G.FlySpeed or Vector3.zero
            local ls = moveDir.Magnitude > 0 and dt * 7 or dt * 3
            currentFlyVelocity = currentFlyVelocity:Lerp(targetVel, math.clamp(ls, 0, 1))
            local safe = ApplyCollisionSlide(hrp, currentFlyVelocity)
            if safe ~= currentFlyVelocity then
                currentFlyVelocity = safe
            end
            flyBodyVelocity.Velocity = safe
        end
    end

    if _G.TPWalkEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.MoveDirection.Magnitude > 0 then
            LocalPlayer.Character.HumanoidRootPart.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame + hum.MoveDirection * _G.TPWalkSpeed * 0.1
        end
    end
end)

task.spawn(function()
    while task.wait(1) do
        if not _G.NB5_Running then
            break
        end
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                if _G.ESP_Names then
                    CreateNameTag(p)
                end
                if _G.ESP_Chams then
                    CreateChams(p)
                end
                if _G.MM2_ESP then
                    local role = "Innocent"
                    if p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife") then
                        role = "Murderer"
                    elseif p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun") then
                        role = "Sheriff"
                    end
                    local h = p.Character:FindFirstChild("MM2_Highlight") or Instance.new("Highlight", p.Character)
                    h.Name = "MM2_Highlight"
                    h.FillTransparency = 0.5
                    if role == "Murderer" then
                        h.FillColor = Color3.fromRGB(255, 0, 0)
                    elseif role == "Sheriff" then
                        h.FillColor = Color3.fromRGB(0, 0, 255)
                    else
                        h.FillColor = Color3.fromRGB(0, 255, 0)
                    end
                end
            end
        end
        if _G.AntiAFK then
            pcall(function()
                LocalPlayer:Move(Vector3.new(0, 0, 0), false)
            end)
        end
    end
end)

