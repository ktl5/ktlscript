                local moveX = (screenPos.X - mouseLocation.X) * _G.AimLock_Smoothness
                local moveY = (screenPos.Y - mouseLocation.Y) * _G.AimLock_Smoothness
                if mousemoverel then mousemoverel(moveX, moveY) end
            end
        end
    end

    if _G.TPWalkEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
