local function checkKey(input)
    if lockedOut then
        kStatus.Text = "Système verrouillé."
        kStatus.TextColor3 = Color3.fromRGB(255, 69, 58)
        return false
    end
    if input == CORRECT_KEY then
        authenticated = true
        kStatus.Text = "✓ Accès accordé"
        kStatus.TextColor3 = Color3.fromRGB(10, 132, 255)
        kSubmit.BackgroundColor3 = Color3.fromRGB(10, 132, 255)
        kSubmit.Text = "Succès"
        TweenService:Create(keyMain, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = UDim2.new(0, 0, 0, 0)}):Play()
        task.wait(0.3)
        keyGui:Destroy()
        return true
    else
        attempts = attempts + 1
        if attempts >= maxAttempts then
            lockedOut = true
            kStatus.Text = "❌ Trop de tentatives"
            kStatus.TextColor3 = Color3.fromRGB(255, 69, 58)
            kSubmit.Text = "Verrouillé"
            kSubmit.BackgroundColor3 = Color3.fromRGB(80, 0, 0)
            kSubmit.Active = false
            TweenService:Create(keyMain, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = UDim2.new(0, 0, 0, 0)}):Play()
            task.wait(0.3)
            keyGui:Destroy()
            return false
        else
            kStatus.Text = (maxAttempts - attempts) .. " tentative(s) restante(s)"
            kStatus.TextColor3 = Color3.fromRGB(255, 159, 10)
            keyInput.Text = ""
            keyInput:CaptureFocus()
            return false
        end
    end
end

