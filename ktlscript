    -- --- CORE LOGIC ---
    task.spawn(function()
        while task.wait(1) do
            if not _G.KTL5_Running then break end
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    if _G.ESP_Names then CreateNameTag(p) end
                    if _G.ESP_Chams then CreateChams(p) end
                    if _G.MM2_ESP then
                        local role = "Innocent"
                        if p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife") then role = "Murderer"
                        elseif p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun") then role = "Sheriff" end
                        local h = p.Character:FindFirstChild("MM2_Highlight") or Instance.new("Highlight", p.Character)
                        h.Name = "MM2_Highlight"
                        h.FillTransparency = 0.5
                        if role == "Murderer" then h.FillColor = Color3.fromRGB(255, 0, 0)
                        elseif role == "Sheriff" then h.FillColor = Color3.fromRGB(0, 0, 255)
                        else h.FillColor = Color3.fromRGB(0, 255, 0) end
                    end
                end
            end
        end
    end)

    UIS.JumpRequest:Connect(function()
        if _G.InfJump and _G.KTL5_Running then
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum:ChangeState("Jumping") end
        end
    end)

    local isDashing = false 
    RunService.Stepped:Connect(function()
        if not _G.KTL5_Running then return end
        if _G.Noclip and LocalPlayer.Character then
            for _, v in pairs(LocalPlayer.Character:GetDescendants()) do if v:IsA("BasePart") and v.CanCollide then v.CanCollide = false end end
        end
        LocalPlayer.DevCameraOcclusionMode = _G.CameraNoclip and Enum.DevCameraOcclusionMode.Invisicam or Enum.DevCameraOcclusionMode.Zoom
        
        if _G.DashBoost_Enabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = LocalPlayer.Character.HumanoidRootPart
            local vel = hrp.Velocity
            if vel.Magnitude > 75 and not isDashing then 
                isDashing = true
                local dashDirection = vel.Unit
                local boostVelocity = Instance.new("BodyVelocity")
                boostVelocity.MaxForce = Vector3.new(100000, 0, 100000)
                boostVelocity.Velocity = dashDirection * (vel.Magnitude * 1.5)
                boostVelocity.Parent = hrp
                local duration = _G.DashBoost_Multiplier * 0.05
                task.wait(duration)
                if boostVelocity and boostVelocity.Parent then
                    for i = 1, 5 do
                        boostVelocity.Velocity = boostVelocity.Velocity * 0.6
                        task.wait(0.02)
                    end
                    boostVelocity:Destroy()
                end
                task.wait(0.3) 
                isDashing = false
            end
        end
    end)

    RunService.RenderStepped:Connect(function()
        if not _G.KTL5_Running then return end
        if _G.AimLock_Enabled and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            local t = GetClosestPlayer()
            if t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") and mousemoverel then
                local pos = Camera:WorldToViewportPoint(t.Character.HumanoidRootPart.Position)
                local mouseLoc = UIS:GetMouseLocation()
                mousemoverel((pos.X - mouseLoc.X) * _G.AimLock_Smoothness, (pos.Y - mouseLoc.Y) * _G.AimLock_Smoothness)
            end
        end
        FOVCircle.Position = UIS:GetMouseLocation()
        
        -- Smooth Fly Logic
        if _G.FlyEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = LocalPlayer.Character.HumanoidRootPart
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            
            if not hrp:FindFirstChild("KTL5_FlyBV") then
                if hum then hum.PlatformStand = true end
                flyBodyVelocity = Instance.new("BodyVelocity")
                flyBodyVelocity.Name = "KTL5_FlyBV"
                flyBodyVelocity.MaxForce = Vector3.new(100000, 100000, 100000)
                flyBodyVelocity.Velocity = Vector3.zero
                flyBodyVelocity.Parent = hrp

                flyBodyGyro = Instance.new("BodyGyro")
                flyBodyGyro.Name = "KTL5_FlyBG"
                flyBodyGyro.MaxTorque = Vector3.new(100000, 100000, 100000)
                flyBodyGyro.P = 10000
                flyBodyGyro.CFrame = Camera.CFrame
                flyBodyGyro.Parent = hrp
            end
            
            if flyBodyVelocity and flyBodyGyro and flyBodyGyro.Parent == hrp then
                if hum then hum.PlatformStand = true end
                flyBodyGyro.CFrame = Camera.CFrame
                
                local moveDir = Vector3.new()
                if UIS:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + Camera.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - Camera.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - Camera.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + Camera.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
                if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir = moveDir - Vector3.new(0, 1, 0) end

                if moveDir.Magnitude > 0 then
                    moveDir = moveDir.Unit
                end
                flyBodyVelocity.Velocity = moveDir * _G.FlySpeed
            end
        end

        if _G.TPWalkEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.MoveDirection.Magnitude > 0 then LocalPlayer.Character.HumanoidRootPart.CFrame += (hum.MoveDirection * _G.TPWalkSpeed * 0.1) end
        end
    end)

    UIS.InputBegan:Connect(function(i, gp)
        if gp or not _G.KTL5_Running then return end
        if i.KeyCode == Enum.KeyCode.G then _G.AimLock_Enabled = not _G.AimLock_Enabled AimToggle:SetValue(_G.AimLock_Enabled) end
        if i.KeyCode == Enum.KeyCode.CapsLock then _G.CameraNoclip = not _G.CameraNoclip CamNoclipToggle:SetValue(_G.CameraNoclip) end
        
        -- Fly Keybind (V)
        if i.KeyCode == Enum.KeyCode.V then 
            _G.FlyEnabled = not _G.FlyEnabled 
            FlyToggle:SetValue(_G.FlyEnabled)
            if not _G.FlyEnabled then CleanUpFly() end
        end

        if _G.ClickTP_Enabled and i.UserInputType == Enum.UserInputType.MouseButton1 and UIS:IsKeyDown(Enum.KeyCode.LeftControl) then
            if LocalPlayer.Character then LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(Mouse.Hit.p + Vector3.new(0, 3, 0)) end
        end
    end)

