local function createSlider(tabName, label, min, max, default, rounding, callback, saveKey)
    itemOrder += 1
    local value = default or min
    rounding = rounding or 0

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 48)
    frame.BackgroundColor3 = Color3.fromRGB(16, 22, 40)
    frame.BorderSizePixel = 0
    frame.LayoutOrder = itemOrder
    frame.Parent = tabFrames[tabName]
    addCorner(frame, 8)
    addStroke(frame, Color3.fromRGB(30, 55, 90), 1)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.65, 0, 0, 20)
    lbl.Position = UDim2.new(0, 12, 0, 6)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(200, 220, 255)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = frame

    local valLbl = Instance.new("TextLabel")
    valLbl.Size = UDim2.new(0.3, -12, 0, 20)
    valLbl.Position = UDim2.new(0.7, 0, 0, 6)
    valLbl.BackgroundTransparency = 1
    valLbl.Text = tostring(rounding > 0 and math.round(value * 10^rounding) / 10^rounding or math.round(value))
    valLbl.TextColor3 = Color3.fromRGB(0, 180, 255)
    valLbl.Font = Enum.Font.GothamBold
    valLbl.TextSize = 12
    valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.Parent = frame

    local trackBg = Instance.new("Frame")
    trackBg.Size = UDim2.new(1, -24, 0, 6)
    trackBg.Position = UDim2.new(0, 12, 0, 34)
    trackBg.BackgroundColor3 = Color3.fromRGB(25, 35, 65)
    trackBg.BorderSizePixel = 0
    trackBg.Parent = frame
    addCorner(trackBg, 3)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(0, 140, 255)
    fill.BorderSizePixel = 0
    fill.Parent = trackBg
    addCorner(fill, 3)
    local fillGrad = Instance.new("UIGradient")
    fillGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0,  100, 200)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0,  200, 255)),
    })
    fillGrad.Parent = fill

    local thumbSlider = Instance.new("Frame")
    thumbSlider.Size = UDim2.new(0, 12, 0, 12)
    thumbSlider.Position = UDim2.new((value - min) / (max - min), -6, 0.5, -6)
    thumbSlider.BackgroundColor3 = Color3.new(1, 1, 1)
    thumbSlider.BorderSizePixel = 0
    thumbSlider.ZIndex = 2
    thumbSlider.Parent = trackBg
    addCorner(thumbSlider, 6)

    local draggingSlider = false
    local sliderBtn = Instance.new("TextButton")
    sliderBtn.Size = UDim2.new(1, 0, 4, 0)
    sliderBtn.Position = UDim2.new(0, 0, 0.5, -12)
    sliderBtn.BackgroundTransparency = 1
    sliderBtn.Text = ""
    sliderBtn.ZIndex = 3
    sliderBtn.Parent = trackBg

    local function applyValue(v)
        value = v
        local pct = clamp((value - min) / (max - min), 0, 1)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        thumbSlider.Position = UDim2.new(pct, -6, 0.5, -6)
        valLbl.Text = tostring(value)
        if callback then callback(value) end
    end

    local function updateSlider(inputX)
        local absPos  = trackBg.AbsolutePosition.X
        local absSize = trackBg.AbsoluteSize.X
        local pct = clamp((inputX - absPos) / absSize, 0, 1)
        local raw = min + pct * (max - min)
        if rounding == 0 then raw = math.round(raw)
        else raw = math.round(raw * 10^rounding) / 10^rounding end
        applyValue(raw)
    end

    sliderBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingSlider = true
            updateSlider(inp.Position.X)
        end
    end)
    UIS.InputChanged:Connect(function(inp)
        if draggingSlider and inp.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(inp.Position.X)
        end
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingSlider = false
        end
    end)

    if saveKey then
        registerSaveable(saveKey,
            function() return value end,
            function(v)
                local n = tonumber(v)
                if n then applyValue(clamp(n, min, max)) end
            end
        )
    end
end

