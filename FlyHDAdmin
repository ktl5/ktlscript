-- NOCLIP LOGIC
-- ══════════════════════════════════════════════════════════════════════════════
local function updateNoclipLoop()
    if noclipMode or noclipCamMode then
        if not noclipConnection then
            noclipConnection = RunService.Stepped:Connect(function()
                if character then
                    for _, part in pairs(character:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end
            end)
        end
    else
        if noclipConnection then
            noclipConnection:Disconnect()
            noclipConnection = nil
        end
        if character then
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
    end
end

function startNoclip()
    if noclipMode then return end
    noclipMode = true
    noclipStatusValue.Text = "On"
    noclipStatusValue.TextColor3 = statusOn
    noclipBtn.Text = "DISABLE NOCLIP"
    updateNoclipLoop()
end

function stopNoclip()
    if not noclipMode then return end
    noclipMode = false
    noclipStatusValue.Text = "Off"
    noclipStatusValue.TextColor3 = textSecondary
    noclipBtn.Text = "ENABLE NOCLIP"
    updateNoclipLoop()
end

function toggleNoclip()
    if noclipMode then stopNoclip() else startNoclip() end
end

function startNoclipCam()
    if noclipCamMode then return end
    noclipCamMode = true
    noclipCamStatusValue.Text = "On"
    noclipCamStatusValue.TextColor3 = statusOn
    noclipCamBtn.Text = "DISABLE NOCLIP CAM"
    player.DevCameraOcclusionMode = Enum.DevCameraOcclusionMode.Invisicam
    updateNoclipLoop()
end

function stopNoclipCam()
    if not noclipCamMode then return end
    noclipCamMode = false
    noclipCamStatusValue.Text = "Off"
    noclipCamStatusValue.TextColor3 = textSecondary
    noclipCamBtn.Text = "ENABLE NOCLIP CAM"
    player.DevCameraOcclusionMode = Enum.DevCameraOcclusionMode.Zoom
    updateNoclipLoop()
end

function toggleNoclipCam()
    if noclipCamMode then stopNoclipCam() else startNoclipCam() end
end

-- ══════════════════════════════════════════════════════════════════════════════
-- FLY SYSTEM
-- ══════════════════════════════════════════════════════════════════════════════
function startFlying()
    if flying or not character or not rootPart then return end
    flying = true

    statusValue.Text = "On"
    statusValue.TextColor3 = statusOn
    enableBtn.Text = "DISABLE"
    enableBtn.TextColor3 = accentRed

    pos = Instance.new("BodyPosition")
    gyro = Instance.new("BodyGyro")

    pos.Position = rootPart.Position + Vector3.new(0, 3, 0)
    pos.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    pos.P = 55000
    pos.D = 1400

    gyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    gyro.P = 20000
    gyro.D = 800

    pos.Parent = rootPart
    gyro.Parent = rootPart

    humanoid.PlatformStand = true

    heartbeatEvent = RunService.Heartbeat:Connect(function(dt)
        if not flying then return end
        if UserInputService:GetFocusedTextBox() then return end

        local cam = workspace.CurrentCamera
        local moveDir = humanoid.MoveDirection
        local frameSpeed = flySpeed * 5 * FlyMultiplier * (dt * 60)

        local dir = cam.CFrame:VectorToObjectSpace(moveDir * frameSpeed)

        if dir.Magnitude > 0 then
            pos.Position = pos.Position + cam.CFrame:VectorToWorldSpace(
                Vector3.new(dir.X, 0, dir.Z).Unit * dir.Magnitude
            )
        end

        if UserInputService:IsKeyDown(Enum.KeyCode.Space) or UserInputService:IsKeyDown(Enum.KeyCode.R) then
            pos.Position = pos.Position + Vector3.new(0, frameSpeed, 0)
        elseif UserInputService:IsKeyDown(Enum.KeyCode.Q) then
            pos.Position = pos.Position - Vector3.new(0, frameSpeed, 0)
        end

        gyro.CFrame = gyro.CFrame:Lerp(cam.CFrame, 0.3)
        humanoid.PlatformStand = true
    end)
end

function stopFlying()
    if not flying then return end
    flying = false

    statusValue.Text = "Off"
    statusValue.TextColor3 = textSecondary
    enableBtn.Text = "ENABLE"
    enableBtn.TextColor3 = blueA

    if heartbeatEvent then heartbeatEvent:Disconnect() end
    if pos then pos:Destroy() end
    if gyro then gyro:Destroy() end

    humanoid.PlatformStand = false
    humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
end

local loading = false
function toggleFly()
    if loading then return end
    if flying then
        stopFlying()
    else
        loading = true
        enableBtn.Text = "Loading…"
        enableBtn.Active = false
        enableBtn.AutoButtonColor = false

        task.wait(0.1)

        startFlying()

        enableBtn.Active = true
        enableBtn.AutoButtonColor = true
        loading = false
    end
end

