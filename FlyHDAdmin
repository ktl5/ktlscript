-- MINIMIZE
local minimized = false
local animating = false
track(minimizeBtn.MouseButton1Click:Connect(function()
    if animating then return end
    animating = true
    minimized = not minimized
    minimizeBtn.Text = minimized and "+" or "-"
    local targetSize = minimized and UDim2.new(0, 320, 0, 34) or UDim2.new(0, 320, 0, 340)
    local tween = TweenService:Create(mainFrame, TweenInfo.new(SlowM, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = targetSize})
    tween:Play()
    if minimized then
        task.delay(SlowM * 0.6, function() contentFrame.Visible = false end)
    else
        contentFrame.Visible = true
    end
    tween.Completed:Connect(function() animating = false end)
end))

-- DRAG
local dragging = false
local dragStart, startPos

track(titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end))

track(UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end))

track(UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end))

-- KEYBINDS
track(UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.F then
        toggleFly()
    elseif input.KeyCode == Enum.KeyCode.G then
        toggleNoclip()
    elseif input.KeyCode == Enum.KeyCode.CapsLock then
        toggleNoclipCam()
    end
end))

-- COMMANDES CHAT
track(player.Chatted:Connect(function(msg)
    if type(msg) ~= "string" then return end
    if msg == "" then return end
    if msg:sub(1, 1) ~= ";" then return end

    local lower = string.lower(msg)
    local args = string.split(lower, " ")
    local cmd = args[1]

    if cmd == ";ktl" then
        if args[2] and tonumber(args[2]) then
            flySpeed = tonumber(args[2])
            speedBox.Text = " " .. tostring(flySpeed)
        end
        if not flying then startFlying() end
    elseif cmd == ";haku" then
        if flying then stopFlying() end
    elseif cmd == ";noclip" then
        if not noclipMode then startNoclip() end
    elseif cmd == ";clip" then
        if noclipMode then stopNoclip() end
    elseif cmd == ";noclipcam" then
        if not noclipCamMode then startNoclipCam() end
    elseif cmd == ";clipcam" then
        if noclipCamMode then stopNoclipCam() end
    end
end))
