-- ══════════════════════════════════════════════════════════════════════════════
tlClose.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        unloadScript()
    end
end)

local minimized = false
local animating = false

tlMin.InputBegan:Connect(function(i)
    if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
    if animating then return end

    animating = true
    minimized = not minimized

    local tween = TweenService:Create(
        mainFrame,
        TweenInfo.new(SlowM, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
        { Size = UDim2.new(0, WIN_W, 0, minimized and HEADER_H or WIN_H) }
    )

    tween:Play()

    if minimized then
        task.delay(SlowM * 0.45, function()
            content.Visible = false
        end)
    else
        content.Visible = true
    end

    tween.Completed:Connect(function()
        animating = false
    end)
end)

-- ══════════════════════════════════════════════════════════════════════════════
-- DRAG SYSTEM
-- ══════════════════════════════════════════════════════════════════════════════
local dragging = false
local dragStart, startPos

track(header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end))

track(UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local d = input.Position - dragStart
        mainFrame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + d.X,
            startPos.Y.Scale, startPos.Y.Offset + d.Y
        )
    end
end))

track(UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end))

-- ══════════════════════════════════════════════════════════════════════════════
-- KEYBINDS
-- ══════════════════════════════════════════════════════════════════════════════
track(UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end

    if input.KeyCode == Enum.KeyCode.F then
        toggleFly()

    elseif input.KeyCode == Enum.KeyCode.G then
        toggleNoclip()

    elseif input.KeyCode == Enum.KeyCode.CapsLock then
        toggleNoclipCam()

    elseif input.KeyCode == Enum.KeyCode.H then
        if animating then return end

        animating = true
        minimized = not minimized

        local tween = TweenService:Create(
            mainFrame,
            TweenInfo.new(SlowM, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
            { Size = UDim2.new(0, WIN_W, 0, minimized and HEADER_H or WIN_H) }
        )

        tween:Play()

        if minimized then
            task.delay(SlowM * 0.45, function()
                content.Visible = false
            end)
        else
            content.Visible = true
        end

        tween.Completed:Connect(function()
            animating = false
        end)
    end
end))


-- ══════════════════════════════════════════════════════════════════════════════
-- CHAT COMMANDS
-- ══════════════════════════════════════════════════════════════════════════════
track(player.Chatted:Connect(function(msg)
    if type(msg) ~= "string" or msg == "" or msg:sub(1,1) ~= ";" then return end

    local args = string.split(string.lower(msg), " ")
    local cmd = args[1]

    if cmd == ";ktl" then
        if args[2] and tonumber(args[2]) then
            flySpeed = tonumber(args[2])
            speedBox.Text = tostring(flySpeed)
        end
        if not flying then startFlying() end

    elseif cmd == ";haku" then
        if flying then stopFlying() end

    elseif cmd == ";noclip" then
        if not noclipMode then startNoclip() end

    elseif cmd == ";clip" then
        if noclipMode then stopNoclip() end

    elseif cmd == ";noclipcam" then
        if not noclipCamMode then startNoclipCam() end

    elseif cmd == ";clipcam" then
        if noclipCamMode then stopNoclipCam() end
    end
end))
