local function applyCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 12)
    c.Parent = parent
    return c
end

local function applyStroke(parent, color, thickness, trans)
    local s = Instance.new("UIStroke")
    s.Color = color or borderCol
    s.Thickness = thickness or 1
    s.Transparency = trans or BG_TRANS
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function makeLabel(parent, text, size, color, xAlign, pos_, sz_)
    local l = Instance.new("TextLabel")
    l.Parent = parent
    l.BackgroundTransparency = 1
    l.Text = text
    l.Font = Enum.Font.GothamMedium
    l.TextSize = size or 13
    l.TextColor3 = color or textPrimary
    l.TextXAlignment = xAlign or Enum.TextXAlignment.Left
    if pos_ then l.Position = pos_ end
    if sz_  then l.Size = sz_  end
    return l
end

