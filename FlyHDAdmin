-- VOL
function startFlying()
    if flying or not character or not rootPart then return end
    flying = true
    statusValue.Text = "On"
    statusValue.TextColor3 = green
    enableBtn.Text = "DISABLE"

    pos = Instance.new("BodyPosition")
    gyro = Instance.new("BodyGyro")

    pos.Position = rootPart.Position + Vector3.new(0, 3, 0)
    pos.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    pos.P = 55000
    pos.D = 1400

    gyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    gyro.P = 20000
    gyro.D = 800

    pos.Parent = rootPart
    gyro.Parent = rootPart

    humanoid.PlatformStand = true

    heartbeatEvent = RunService.Heartbeat:Connect(function(dt)
        if not flying then return end
        if UserInputService:GetFocusedTextBox() then return end

        local cam = workspace.CurrentCamera
        local moveDir = humanoid.MoveDirection
        local frameSpeed = flySpeed * 5 * FlyMultiplier * (dt * 60)
        local travel = moveDir * frameSpeed
        local dir = cam.CFrame:VectorToObjectSpace(travel)

        if dir.Magnitude > 0 then
            local worldDir = cam.CFrame:VectorToWorldSpace(
                Vector3.new(dir.X, 0, dir.Z).Unit * dir.Magnitude
            )
            pos.Position = pos.Position + worldDir
        end

        if UserInputService:IsKeyDown(Enum.KeyCode.Space) or UserInputService:IsKeyDown(Enum.KeyCode.R) then
            pos.Position = pos.Position + Vector3.new(0, frameSpeed, 0)
        elseif UserInputService:IsKeyDown(Enum.KeyCode.Q) then
            pos.Position = pos.Position - Vector3.new(0, frameSpeed, 0)
        end

        gyro.CFrame = gyro.CFrame:Lerp(cam.CFrame, 0.3)
        humanoid.PlatformStand = true
    end)
end  -- ← fin de startFlying()

function stopFlying()
    if not flying then return end
    flying = false
    statusValue.Text = "Off"
    statusValue.TextColor3 = red
    enableBtn.Text = "ENABLE"

    if heartbeatEvent then heartbeatEvent:Disconnect() end
    if pos then pos:Destroy() end
    if gyro then gyro:Destroy() end

    humanoid.PlatformStand = false
    humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
end

local loading = false
function toggleFly()
    if loading then return end
    if flying then
        stopFlying()
    else
        loading = true
        enableBtn.Text = "Loading..."
        enableBtn.Active = false
        enableBtn.AutoButtonColor = false
        task.wait(0.1)
        startFlying()
        enableBtn.Active = true
        enableBtn.AutoButtonColor = true
        loading = false
    end
end

